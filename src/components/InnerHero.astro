---
// InnerHero.astro — banda „hero" a paginilor interioare, replică fidelă a live-ului
// (ex. https://deeabodycenter.ro/tarife/, /contact/, /servicii-.../, /oferte-.../):
//   - bandă gri-deschis (#ECF0F2) sub header
//   - STÂNGA: titlul paginii în Playfair navy, aliniat la stânga, + <Breadcrumb />
//   - DREAPTA (DESKTOP): o fotografie mare (~410px) care „atârnă" sub bandă pe dreapta,
//     cu o decorațiune de grilă de puncte teal (pattern_1.png) în stânga fotografiei.
//   - MOBIL (≤900px): titlul + breadcrumb-ul CENTRATE, fotografia din dreapta ASCUNSĂ
//     (ca pe live), iar decorațiunea de puncte teal apare lângă breadcrumb.
//
// Props:
//   title: string                       — titlul paginii (H1)
//   breadcrumb: Array<{label, href?}>   — crumb-uri DUPĂ „Home" (Home e adăugat auto)
//   image?: string                      — cale fotografie hero (opțional)
//   imageAlt?: string
import Breadcrumb from './Breadcrumb.astro';

interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  title: string;
  breadcrumb: Crumb[];
  image?: string;
  imageAlt?: string;
}
const { title, breadcrumb = [], image, imageAlt = '' } = Astro.props;
---

<section class="inner-hero">
  <div class="inner-hero__inner">
    <div class="inner-hero__text">
      <h1 class="inner-hero__title">{title}</h1>
      <div class="inner-hero__crumb">
        <img
          class="inner-hero__dots-m"
          src="/pattern_1.png"
          width="129"
          height="50"
          alt=""
          aria-hidden="true"
          loading="lazy"
        />
        <Breadcrumb items={breadcrumb} />
      </div>
    </div>

    <div class="inner-hero__media">
      {
        image && (
          <>
            <img
              class="inner-hero__dots"
              src="/pattern_1.png"
              width="129"
              height="50"
              alt=""
              aria-hidden="true"
              loading="lazy"
            />
            <img
              class="inner-hero__photo"
              src={image}
              alt={imageAlt}
              width="410"
              height="410"
              loading="eager"
            />
          </>
        )
      }
    </div>
  </div>
</section>

<style>
  .inner-hero {
    background: #ecf0f2;
    padding-top: 80px;
    position: relative;
    z-index: 1;
    /* Plasă de siguranță: fotografia hero nu poate „atârna" niciodată sub bandă
       peste conținutul de dedesubt (ex. cardurile de preț de pe /oferte-.../). */
    overflow: hidden;
  }
  .inner-hero__inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 15px;
    display: grid;
    /* Coloana de text este lată (~700px) ca pe live, astfel încât titlurile scurte
       („Oferte Tratamente Faciale/Corporale") încap pe UN rând, iar cel lung
       („Oferte speciale…") se rupe pe DOUĂ rânduri — exact ca pe live. */
    grid-template-columns: minmax(0, 700px) minmax(0, 1fr);
    column-gap: 30px;
    align-items: start;
    min-height: 204px;
  }

  /* ===== STÂNGA: titlu + breadcrumb ===== */
  .inner-hero__text {
    padding-bottom: 44px;
    align-self: center;
  }
  .inner-hero__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 48px;
    line-height: 1;
    color: var(--navy, #051145);
    margin: 0 0 26px;
  }
  .inner-hero__crumb {
    position: relative;
  }
  /* Decorațiune de puncte pentru breadcrumb — vizibilă doar pe mobil (ca pe live) */
  .inner-hero__dots-m {
    display: none;
  }

  /* ===== DREAPTA: fotografie + decorațiune puncte ===== */
  .inner-hero__media {
    position: relative;
    align-self: stretch;
  }
  /* Fotografia din dreapta — pătrat de 235px (ca pe live /oferte-.../), CONȚINUT
     strict în bandă: se ridică în zona de padding (top negativ) până lângă marginea
     de sus a benzii, dar marginea ei de jos rămâne DEASUPRA marginii de jos a benzii
     (140px → 375px, sub band-bottom 408px), deci nu suprapune niciodată cardurile de
     preț de dedesubt. `overflow:hidden` de pe .inner-hero garantează suplimentar
     că nimic nu poate depăși banda. */
  .inner-hero__photo {
    position: absolute;
    top: -64px;
    right: 0;
    width: 235px;
    height: 235px;
    object-fit: cover;
    display: block;
    z-index: 2;
  }
  /* Decorațiune puncte teal — în stânga fotografiei, suprapusă ~28px peste marginea
     ei din stânga, centrată vertical în bandă (ca pe live). */
  .inner-hero__dots {
    position: absolute;
    top: 30px;
    right: 207px;
    width: 129px;
    height: 50px;
    display: block;
    z-index: 1;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .inner-hero {
      padding-top: 56px;
    }
    .inner-hero__inner {
      grid-template-columns: 1fr;
      min-height: 0;
      row-gap: 0;
    }
    /* Titlu + breadcrumb centrate pe mobil */
    .inner-hero__text {
      padding-bottom: 28px;
      text-align: center;
      align-self: start;
    }
    .inner-hero__title {
      margin-bottom: 20px;
    }
    /* Breadcrumb centrat (nav-ul copil e stilizat prin :global) */
    .inner-hero__text :global(.breadcrumb__list) {
      justify-content: center;
    }
    /* Puncte teal lângă breadcrumb, în stânga, în spatele textului */
    .inner-hero__dots-m {
      display: block;
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 129px;
      height: 50px;
      z-index: 0;
      pointer-events: none;
    }
    .inner-hero__crumb :global(.breadcrumb) {
      position: relative;
      z-index: 1;
    }
    /* Fotografia din dreapta e ascunsă pe mobil (ca pe live) */
    .inner-hero__media {
      display: none;
    }
  }
</style>
