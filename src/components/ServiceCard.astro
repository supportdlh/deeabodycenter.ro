---
// Cardul de tratament folosit în grilele „Tratamente Faciale" (6) și
// „Remodelare Corporală" (9). Portat din mockup-ul V2 aprobat
// (mockups/v2-rafinat/index.html, blocurile .card / .card-img / .card-body).
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  title: string;
  excerpt: string;
  image: ImageMetadata;
  href: string;
}

const { title, excerpt, image, href } = Astro.props;
---

<div class="card">
  <Image class="card-img" src={image} alt={title} width={640} height={400} loading="lazy" />
  <div class="card-body">
    <h3>{title}</h3>
    <p>{excerpt}</p>
    <a href={href} class="card-link">
      Descoperă
      <svg
        width="15"
        height="15"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
        aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
      >
    </a>
  </div>
</div>

<style>
  .card {
    background: var(--surface-card);
    border-radius: var(--r-md);
    box-shadow: var(--sh-sm);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    transition:
      transform var(--t-med),
      box-shadow var(--t-med);
    height: 100%;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--sh-md);
  }
  .card :global(.card-img) {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
  }
  .card-body {
    padding: 20px 24px 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .card-body h3 {
    font-size: 1rem;
    margin-bottom: 8px;
    color: var(--heading);
    line-height: 1.35;
  }
  .card-body p {
    font-size: 0.875rem;
    line-height: 1.65;
    flex: 1;
    margin-bottom: 16px;
  }
  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--magenta);
    margin-top: auto;
    transition: gap var(--t-fast);
  }
  .card-link:hover {
    gap: 10px;
    text-decoration: none;
  }
  .card-link svg {
    flex-shrink: 0;
  }
</style>
