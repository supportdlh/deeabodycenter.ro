---
// Cardul de tratament folosit în grilele „Tratamente Faciale" (6),
// „Remodelare Corporală" (9) și pe pagina hub de servicii.
// Pixel-perfect după mockup-ul V1 aprobat (mockups/v1-clona/index.html,
// blocurile .card / .card-img / .card-body). Cardul întreg e link (mai bun
// pentru UX decât link-ul textual „Descoperă" din original, care oricum
// lipsea de pe majoritatea cardurilor din V1).
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  title: string;
  excerpt: string;
  image: ImageMetadata;
  href: string;
}

const { title, excerpt, image, href } = Astro.props;
---

<a href={href} class="card">
  <Image
    class="card-img"
    src={image}
    alt={title}
    width={640}
    height={400}
    widths={[320, 480, 640]}
    sizes="(max-width: 640px) 90vw, (max-width: 1024px) 45vw, 370px"
    loading="lazy"
  />
  <div class="card-body">
    <h3>{title}</h3>
    <p>{excerpt}</p>
  </div>
</a>

<style>
  .card {
    background: var(--surface-card);
    border-radius: 10px;
    box-shadow: 0 2px 18px rgba(5, 17, 69, 0.09);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
    transition:
      transform 0.22s,
      box-shadow 0.22s;
    height: 100%;
  }
  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 28px rgba(5, 17, 69, 0.15);
    text-decoration: none;
  }
  .card :global(.card-img) {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    flex-shrink: 0;
  }
  .card-body {
    padding: 20px 20px 24px;
    flex: 1;
  }
  .card-body h3 {
    font-size: 1.125rem;
    color: var(--heading);
    margin-bottom: 10px;
    line-height: 1.3;
  }
  .card-body p {
    font-size: 0.84375rem;
    color: var(--text-sec);
    line-height: 1.65;
  }
</style>
