---
// Galerie de imagini (grilă justificată) — reproduce secțiunea de galerie de pe
// paginile live de tratament/ofertă (Elementor `e-gallery-grid` / Swiper), care
// afișează TOATE fotografiile într-o grilă pătrată pe mai multe rânduri (NU un
// carusel orizontal).
//
// Look (măsurat pe LIVE `deeabodycenter.ro`):
//   • eyebrow „Deea Body Center" = Playfair Display, italic, 700, ~14px, teal
//     (rgb(20,138,135)), fără uppercase, centrat;
//   • titlul paginii (serif navy, centrat);
//   • grilă CSS: 4 coloane desktop / 2 coloane mobil, item pătrat (1:1),
//     gap 10px, colțuri rotunjite 10px, object-fit cover;
//   • lightbox simplu click-to-enlarge (JS vanilla minim).
//
// Randat DOAR când `images` are cel puțin un element (vezi utilizarea din
// TreatmentLayout/OfferLayout — condiționată pe `data.gallery?.length`).
export interface Props {
  images: string[];
  title: string;
}

const { images, title } = Astro.props;
---

{
  images.length > 0 && (
    <section class="gallery-section" data-gallery>
      <div class="gallery-heading">
        <span class="eyebrow">Deea Body Center</span>
        <h2>{title}</h2>
      </div>

      <div class="gallery-grid">
        {images.map((src, i) => (
          <a class="gallery-item" href={src} data-slide data-index={i}>
            <img src={src} alt={`${title} — imagine ${i + 1}`} loading="lazy" />
          </a>
        ))}
      </div>

      <div class="lightbox" data-lightbox-overlay hidden>
        <button class="lightbox-close" type="button" data-lightbox-close aria-label="Închide">
          ×
        </button>
        <button class="lightbox-nav lightbox-nav--prev" type="button" data-lightbox-prev aria-label="Imaginea precedentă">
          ‹
        </button>
        <img class="lightbox-img" data-lightbox-img alt="" />
        <button class="lightbox-nav lightbox-nav--next" type="button" data-lightbox-next aria-label="Imaginea următoare">
          ›
        </button>
      </div>
    </section>
  )
}

<style>
  .gallery-section {
    background: var(--surface);
  }

  .gallery-heading {
    padding: 48px 24px 0;
    text-align: center;
  }
  .eyebrow {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 0.875rem;
    font-weight: 700;
    font-style: italic;
    letter-spacing: normal;
    text-transform: none;
    color: var(--teal);
    display: block;
    margin-bottom: 10px;
  }
  .gallery-heading h2 {
    font-size: 2.625rem;
    margin-bottom: 0;
  }

  /* ===== JUSTIFIED GRID ===== */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    max-width: 1140px;
    margin: 0 auto;
    padding: 32px 24px 56px;
  }
  .gallery-item {
    position: relative;
    display: block;
    aspect-ratio: 1 / 1;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: var(--sh-sm);
    transition:
      transform var(--t-med),
      box-shadow var(--t-med);
  }
  .gallery-item:hover {
    transform: translateY(-4px);
    box-shadow: var(--sh-md);
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ===== LIGHTBOX ===== */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(5, 17, 69, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lightbox[hidden] {
    display: none;
  }
  .lightbox-img {
    max-width: 88vw;
    max-height: 84vh;
    border-radius: 8px;
    box-shadow: var(--sh-lg);
  }
  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
  }
  .lightbox-close:hover {
    background: var(--magenta);
  }
  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
  }
  .lightbox-nav:hover {
    background: var(--magenta);
  }
  .lightbox-nav--prev {
    left: 16px;
  }
  .lightbox-nav--next {
    right: 16px;
  }

  @media (max-width: 768px) {
    .gallery-heading {
      padding-top: 40px;
    }
    .gallery-heading h2 {
      font-size: 1.875rem;
    }
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      padding: 24px 16px 40px;
    }
  }
</style>

<script>
  // JS vanilla minim, scoped pe fiecare instanță de galerie (nu presupune o
  // singură galerie per pagină, deși în practică fiecare pagină are cel mult una).
  function initGallery(root: Element) {
    // Lightbox (click-to-enlarge)
    const overlay = root.querySelector<HTMLElement>('[data-lightbox-overlay]');
    const imgEl = overlay?.querySelector<HTMLImageElement>('[data-lightbox-img]');
    const slides = Array.from(root.querySelectorAll<HTMLAnchorElement>('[data-slide]'));
    let current = 0;

    function openLightbox(index: number) {
      current = index;
      const slide = slides[current];
      if (!slide || !imgEl || !overlay) return;
      imgEl.src = slide.getAttribute('href') ?? '';
      imgEl.alt = slide.querySelector('img')?.alt ?? '';
      overlay.hidden = false;
      document.body.style.overflow = 'hidden';
    }
    function closeLightbox() {
      if (!overlay) return;
      overlay.hidden = true;
      document.body.style.overflow = '';
    }
    function step(dir: number) {
      if (slides.length === 0) return;
      openLightbox((current + dir + slides.length) % slides.length);
    }

    slides.forEach((slide, i) => {
      slide.addEventListener('click', (e) => {
        e.preventDefault();
        openLightbox(i);
      });
    });

    overlay?.querySelector('[data-lightbox-close]')?.addEventListener('click', closeLightbox);
    overlay?.addEventListener('click', (e) => {
      if (e.target === overlay) closeLightbox();
    });
    overlay?.querySelector('[data-lightbox-prev]')?.addEventListener('click', () => step(-1));
    overlay?.querySelector('[data-lightbox-next]')?.addEventListener('click', () => step(1));

    document.addEventListener('keydown', (e) => {
      if (!overlay || overlay.hidden) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') step(-1);
      if (e.key === 'ArrowRight') step(1);
    });
  }

  document.querySelectorAll('[data-gallery]').forEach(initGallery);
</script>
