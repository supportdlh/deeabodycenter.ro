---
import { Image } from 'astro:assets';
import logo from '../assets/deea-body-center5.webp';
import { site } from '../data/site';
import { nav } from '../data/nav';

const oferteLinks = nav.find((item) => item.label === 'Oferte')?.children ?? [];

const serviciiLinks = [
  { label: 'Servicii Tratamente Faciale și Corporale', href: '/servicii-tratamente-faciale-si-corporale/' },
  { label: 'Tratament Sculptor', href: '/tratament-sculptor/' },
  { label: 'Tratament HidratIQ', href: '/tratament-hidratiq/' },
  { label: 'Criolipoliza Cryogen', href: '/criolipoliza/' },
];
---

<footer class="site-footer">
  <div class="footer-body">
    <div class="footer-col footer-col--brand">
      <a href="/">
        <Image class="footer-logo" src={logo} alt={site.name} width={92} height={92} loading="lazy" />
      </a>
      <p class="footer-slogan">{site.tagline}</p>
      <div class="footer-social">
        <a href={site.social.facebook || '#'} aria-label="Facebook">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
            ><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg
          >
        </a>
        <a href={site.social.instagram || '#'} aria-label="Instagram">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><rect x="2" y="2" width="20" height="20" rx="5"></rect><path
              d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"
            ></line></svg
          >
        </a>
      </div>
    </div>

    <div class="footer-col">
      <h4>Servicii</h4>
      <ul>
        {
          serviciiLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="footer-col">
      <h4>Oferte</h4>
      <ul>
        {
          oferteLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="footer-col">
      <h4>Program</h4>
      <ul>
        {
          site.hours.map((h) => (
            <li>
              <span class="prog-day">
                {h.days}
                {h.open && h.close ? '' : ' – Închis'}
              </span>
              {h.open && h.close && <span class="prog-time">{h.open} – {h.close}</span>}
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      &copy; 2022 {site.name}. Creare site – <a href="https://digitalhelp.ro" target="_blank" rel="noopener">digitalhelp.ro</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #ecf0f2;
    color: var(--navy);
  }

  .footer-body {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 40px;
    max-width: 1170px;
    margin: 0 auto;
    padding: 56px 24px 44px;
  }
  .footer-logo {
    height: 54px;
    width: auto;
    margin-bottom: 16px;
  }
  .footer-slogan {
    font-size: 13.5px;
    color: var(--navy);
    line-height: 1.65;
    margin-bottom: 18px;
  }

  .footer-social {
    display: flex;
    gap: 10px;
    align-items: center;
  }
  .footer-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #fff;
    color: #1c7261;
    transition:
      background var(--t-fast),
      color var(--t-fast);
  }
  .footer-social a:hover {
    background: var(--magenta);
    color: #fff;
    text-decoration: none;
  }

  .footer-col h4 {
    font-family: 'Poppins', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: var(--navy);
    margin-bottom: 16px;
  }
  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col ul li a {
    font-size: 14px;
    color: var(--navy);
    transition: color var(--t-fast);
  }
  .footer-col ul li a:hover {
    color: var(--magenta-h);
    text-decoration: none;
  }
  .footer-col ul li .prog-day,
  .footer-col ul li .prog-time {
    display: block;
    font-size: 14px;
    color: var(--navy);
  }

  .footer-bottom {
    border-top: 1px solid rgba(5, 17, 69, 0.1);
  }
  .footer-bottom-inner {
    max-width: 1170px;
    margin: 0 auto;
    padding: 16px 24px;
    text-align: center;
    font-size: 12px;
    color: var(--navy);
  }
  .footer-bottom-inner a {
    color: #1c7261;
  }

  @media (max-width: 900px) {
    .footer-body {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .footer-body {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    /* pe mobil, ca pe live, coloana de brand (logo/slogan/social) e centrată în capul footer-ului */
    .footer-body .footer-col--brand {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .footer-body .footer-col--brand .footer-social {
      justify-content: center;
    }
  }
</style>
