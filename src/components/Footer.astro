---
import { Image } from 'astro:assets';
import logo from '../assets/deea-body-center5.webp';
import { site } from '../data/site';
import { nav } from '../data/nav';

const oferteLinks = nav.find((item) => item.label === 'Oferte')?.children ?? [];

const serviciiLinks = [
  { label: 'Servicii Tratamente Faciale și Corporale', href: '/servicii-tratamente-faciale-si-corporale/' },
  { label: 'Tratament Sculptor', href: '/tratament-sculptor/' },
  { label: 'Tratament HidratIQ', href: '/tratament-hidratiq/' },
  { label: 'Criolipoliza Cryogen', href: '/criolipoliza/' },
];
---

<footer class="site-footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <a href="/">
          <Image class="footer-logo" src={logo} alt={site.name} width={92} height={92} loading="lazy" />
        </a>
        <p class="footer-slogan">{site.tagline}</p>
        <div class="footer-social">
          <a href={site.social.facebook || '#'} aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
              ><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg
            >
          </a>
          <a href={site.social.instagram || '#'} aria-label="Instagram">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><rect x="2" y="2" width="20" height="20" rx="5"></rect><path
                d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"
              ></line></svg
            >
          </a>
        </div>
      </div>

      <div class="footer-col">
        <h3>Servicii</h3>
        <ul>
          {
            serviciiLinks.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer-col">
        <h3>Oferte</h3>
        <ul>
          {
            oferteLinks.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer-col">
        <h3>Program</h3>
        <div class="footer-program">
          {
            site.hours.map((h) => (
              <p>
                {h.days}
                <br />
                {h.open && h.close ? `${h.open} – ${h.close}` : 'Închis'}
              </p>
            ))
          }
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span>&copy; 2022 {site.name}.</span>
      <span>Creare site: <a href="https://digitalhelp.ro" target="_blank" rel="noopener">digitalhelp.ro</a></span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--navy);
    color: rgba(255, 255, 255, 0.7);
    padding: 80px 0 32px;
  }
  .wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 64px;
  }
  .footer-logo {
    height: 46px;
    width: auto;
    filter: brightness(0) invert(1);
    margin-bottom: 16px;
  }
  .footer-slogan {
    font-size: 0.9375rem;
    font-style: italic;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
    margin-bottom: 24px;
  }

  .footer-social {
    display: flex;
    gap: 12px;
  }
  .footer-social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    color: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition:
      color var(--t-fast),
      border-color var(--t-fast),
      background var(--t-fast);
  }
  .footer-social a:hover {
    color: #fff;
    border-color: var(--magenta);
    background: rgba(167, 64, 143, 0.28);
    text-decoration: none;
  }

  .footer-col h3 {
    font-family: 'Poppins', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #fff;
    margin-bottom: 20px;
  }
  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col ul li a {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.6);
    transition: color var(--t-fast);
  }
  .footer-col ul li a:hover {
    color: #fff;
    text-decoration: none;
  }

  .footer-program {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-program p {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.5;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 24px;
    display: flex;
    justify-content: center;
    gap: 6px;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.55);
    flex-wrap: wrap;
  }
  .footer-bottom a {
    color: rgba(255, 255, 255, 0.48);
  }
  .footer-bottom a:hover {
    color: #fff;
    text-decoration: none;
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
