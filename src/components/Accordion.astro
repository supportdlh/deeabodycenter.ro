---
// Element de acordeon FAQ, nativ <details>/<summary> (fără JS).
// Pixel-perfect după mockup-ul V1 (mockups/v1-clona/index.html,
// blocurile details.faq-item / summary / .faq-answer) — fără card/box,
// doar bordură inferioară + indicator „+"/„−".
export interface Props {
  title: string;
  open?: boolean;
}

const { title, open = false } = Astro.props;
---

<details class="faq-item" open={open}>
  <summary>{title}</summary>
  <div class="faq-answer">
    <slot />
  </div>
</details>

<style>
  details.faq-item {
    border-bottom: 1px solid var(--border);
  }
  details.faq-item:first-of-type {
    border-top: 1px solid var(--border);
  }
  details.faq-item summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    padding: 15px 4px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--heading);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  details.faq-item summary::-webkit-details-marker {
    display: none;
  }
  details.faq-item summary::after {
    content: '+';
    font-size: 1.375rem;
    font-weight: 400;
    color: var(--magenta);
    flex-shrink: 0;
    line-height: 1;
  }
  details.faq-item[open] summary::after {
    content: '\2212';
  }
  details.faq-item .faq-answer {
    padding: 0 4px 16px;
    font-size: 0.84375rem;
    color: var(--text-sec);
    line-height: 1.72;
  }
  .faq-answer :global(p + p) {
    margin-top: 10px;
  }
</style>
