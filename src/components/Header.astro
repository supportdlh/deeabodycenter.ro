---
import { Image } from 'astro:assets';
import logo from '../assets/deea-body-center5.webp';
import { site } from '../data/site';
import { nav, type NavItem } from '../data/nav';
import WhatsAppButton from './WhatsAppButton.astro';

const currentPath = Astro.url.pathname;
const norm = (p: string) => (p.length > 1 ? p.replace(/\/$/, '') : p);
const isActive = (href: string) => norm(href) === norm(currentPath);

// Grupează copiii unui dropdown pe categorii, sparte de marcajele `heading: true`
// (ex. Servicii → „Tratamente faciale” + „Tratamente corporale”). Un dropdown fără
// heading-uri (ex. Oferte) devine un singur grup fără etichetă → listă simplă.
// Dropdown-urile cu 2+ grupuri devin mega-meniu (coloane pe desktop, acordeoane pe mobil).
interface NavGroup {
  label?: string;
  items: { label: string; href: string }[];
}
function groupChildren(children: NavItem['children']): NavGroup[] {
  const groups: NavGroup[] = [];
  for (const child of children ?? []) {
    if (child.heading) {
      groups.push({ label: child.label, items: [] });
    } else {
      if (groups.length === 0) groups.push({ items: [] });
      groups[groups.length - 1].items.push({ label: child.label, href: child.href });
    }
  }
  return groups;
}
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-logo" aria-label={`${site.name} — pagina principală`}>
      <Image src={logo} alt={site.name} width={208} height={208} loading="eager" />
    </a>

    <input type="checkbox" id="nav-cb" class="nav-cb" />

    <nav class="main-nav" aria-label="Navigare principală">
      <ul class="nav-list">
        {
          nav.map((item) => {
            const groups = item.children ? groupChildren(item.children) : [];
            const isMega = groups.length > 1;
            return (
              <li class="nav-item">
                {item.children ? (
                  <details class="nav-dropdown">
                    <summary class={isActive(item.href) ? 'is-active' : undefined}>
                      {item.label}
                      <span class="caret" aria-hidden="true"></span>
                    </summary>
                    {isMega ? (
                      <div class="dropdown-panel mega">
                        {groups.map((g) => (
                          <details class="svc-group">
                            <summary class="svc-group-h">
                              <span>{g.label}</span>
                              <span class="svc-group-meta">
                                <span class="svc-count">{g.items.length}</span>
                                <span class="caret caret--sub" aria-hidden="true"></span>
                              </span>
                            </summary>
                            <ul>
                              {g.items.map((c) => (
                                <li>
                                  <a href={c.href}>{c.label}</a>
                                </li>
                              ))}
                            </ul>
                          </details>
                        ))}
                      </div>
                    ) : (
                      <ul class="dropdown-panel">
                        {groups[0].items.map((c) => (
                          <li>
                            <a href={c.href}>{c.label}</a>
                          </li>
                        ))}
                      </ul>
                    )}
                  </details>
                ) : (
                  <a href={item.href} class={isActive(item.href) ? 'is-active' : undefined}>
                    {item.label}
                  </a>
                )}
              </li>
            );
          })
        }
      </ul>
    </nav>

    <div class="nav-cta">
      <WhatsAppButton variant="nav" label="PROGRAMARE" />
    </div>

    <label for="nav-cb" class="hamburger" aria-label="Deschide meniu">
      <span></span><span></span><span></span>
    </label>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 200;
    background: var(--surface);
    box-shadow: var(--sh-sm);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 10px 24px;
    max-width: 1140px;
    margin: 0 auto;
  }
  .site-logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }
  .site-logo :global(img) {
    height: 104px;
    width: auto;
  }

  /* nav toggle (checkbox-hack CSS-only) */
  .nav-cb {
    display: none;
  }
  .hamburger {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    cursor: pointer;
    box-sizing: border-box;
    width: 33px;
    height: 33px;
    padding: 5.5px;
    background: rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 3px;
    order: 3;
  }
  .hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition:
      transform var(--t-fast),
      opacity var(--t-fast);
  }

  .main-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
  }
  .nav-list {
    display: flex;
    align-items: center;
    gap: 28px;
    list-style: none;
  }
  .nav-item {
    position: relative;
  }
  .main-nav a {
    display: block;
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
    transition: color var(--t-fast);
  }
  .main-nav a:hover {
    color: var(--magenta);
    text-decoration: none;
  }

  /* active/current page — teal with teal underline (match live) */
  .main-nav a.is-active,
  .nav-dropdown summary.is-active {
    position: relative;
    color: rgb(20, 138, 135);
  }
  .main-nav a.is-active::after,
  .nav-dropdown summary.is-active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -18px;
    height: 2px;
    background: rgb(20, 138, 135);
  }

  /* dropdown Oferte/Servicii — <details>/<summary>, fără JS */
  .nav-dropdown summary {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: color var(--t-fast);
  }
  .nav-dropdown summary::-webkit-details-marker {
    display: none;
  }
  .nav-dropdown summary:hover {
    color: var(--magenta);
  }
  .caret {
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid currentColor;
    transition: transform var(--t-fast);
  }
  .nav-dropdown[open] .caret {
    transform: rotate(180deg);
  }
  .dropdown-panel {
    list-style: none;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    box-shadow: var(--sh-md);
    padding: 8px;
    min-width: 260px;
  }
  .dropdown-panel a {
    font-size: 0.875rem;
    padding: 8px 10px;
    white-space: normal;
  }
  /* ---- mega-meniu (Servicii): coloane pe desktop, acordeoane pliate pe mobil ---- */
  .dropdown-panel.mega {
    min-width: 0;
  }
  .svc-group > ul {
    list-style: none;
  }
  .svc-group-h {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    list-style: none;
    color: var(--teal);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 8px 10px 6px;
  }
  .svc-group-h::-webkit-details-marker {
    display: none;
  }
  .svc-group-meta {
    display: none;
    align-items: center;
    gap: 8px;
  }
  .svc-count {
    font-size: 0.75rem;
    color: var(--text-sec);
    font-weight: 500;
  }
  .caret--sub {
    transition: transform var(--t-fast);
  }
  .svc-group[open] .caret--sub {
    transform: rotate(180deg);
  }

  .nav-cta {
    flex-shrink: 0;
  }

  @media (min-width: 769px) {
    .nav-dropdown {
      position: static;
    }
    .dropdown-panel {
      position: absolute;
      top: calc(100% + 6px);
      left: 0;
    }
    /* Servicii → două coloane (Faciale · Corporale), pe jumătate din înălțime */
    .dropdown-panel.mega {
      display: grid;
      grid-template-columns: repeat(2, minmax(190px, 220px));
      gap: 2px 20px;
      max-width: calc(100vw - 32px);
    }
    /* pe desktop grupurile sunt mereu „deschise” — coloane, nu acordeon.
       Acoperă ambele modele de <details>: cel vechi (conținut ascuns cu display:none,
       suprascris mai jos) și cel nou din Chrome/Safari (pseudo-elementul ::details-content
       cu content-visibility, care nu răspunde la display pe copil). */
    .svc-group::details-content {
      content-visibility: visible;
      height: auto;
    }
    .svc-group > ul {
      display: block !important;
    }
    .svc-group-h {
      cursor: default;
    }
  }

  @media (max-width: 768px) {
    .hamburger {
      display: flex;
    }
    /* mobile top bar = logo + hamburger only (match live) */
    .nav-cta {
      display: none;
    }
    .site-logo :global(img) {
      height: 130px;
    }
    .main-nav a.is-active::after,
    .nav-dropdown summary.is-active::after {
      display: none;
    }
    .header-inner {
      flex-wrap: wrap;
      position: relative;
    }
    .main-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--surface);
      flex-direction: column;
      align-items: flex-start;
      padding: 20px 24px;
      box-shadow: var(--sh-md);
      z-index: 300;
    }
    .nav-cb:checked ~ .main-nav {
      display: flex;
    }
    .nav-list {
      flex-direction: column;
      align-items: flex-start;
      width: 100%;
      gap: 16px;
    }
    .main-nav a,
    .nav-dropdown summary {
      width: 100%;
    }
    .dropdown-panel {
      box-shadow: none;
      border: none;
      background: transparent;
      padding: 0 0 4px 12px;
    }
    /* Servicii pe mobil: categoriile (Faciale/Corporale) = acordeoane pliate */
    .dropdown-panel.mega {
      display: block;
    }
    .svc-group-h {
      cursor: pointer;
      width: 100%;
      color: var(--text);
      font-size: 0.9375rem;
      font-weight: 500;
      text-transform: none;
      letter-spacing: normal;
      padding: 10px 0;
    }
    .svc-group-meta {
      display: flex;
    }
    .svc-group > ul {
      padding: 0 0 6px 12px;
    }
  }
</style>
