---
// O „lamelă" (slide) în slider-ul „Ce spun ele" — pixel-perfect după live
// (deeabodycenter.ro): quote mark teal, text centrat, 5 stele aurii, nume navy,
// totul pe fundal alb (cardul alb e randat de secțiunea părinte din index.astro).
export interface Props {
  name: string;
  text: string;
}

const { name, text } = Astro.props;
---

<div class="testi-slide">
  <span class="quote-mark" aria-hidden="true">&rdquo;</span>
  <p class="testi-text">{text}</p>
  <span class="stars" aria-hidden="true">★★★★★</span>
  <div class="testi-author">{name}</div>
</div>

<style>
  .testi-slide {
    flex: 0 0 100%;
    width: 100%;
    scroll-snap-align: start;
    text-align: center;
  }
  .quote-mark {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 3.75rem;
    font-weight: 700;
    color: var(--teal);
    line-height: 0.6;
    margin-bottom: 14px;
    display: block;
  }
  .testi-text {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--text-sec);
    max-width: 44ch;
    margin: 0 auto 20px;
  }
  .stars {
    color: var(--gold);
    font-size: 1.25rem;
    letter-spacing: 3px;
    margin-bottom: 14px;
    display: block;
  }
  .testi-author {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 1.0625rem;
    color: var(--navy);
  }
</style>
