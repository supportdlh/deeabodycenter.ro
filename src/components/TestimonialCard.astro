---
// O „lamelă" (slide) în slider-ul „Ce spun ele" — pixel-perfect după live
// (deeabodycenter.ro): text citat navy centrat, 5 stele aurii, apoi avatarul
// rotund al clientei + numele. Eyebrow-ul „Testimonial", titlul „Ce spun ele"
// și semnul mare de citat teal sunt fixe (randate de secțiunea părinte).
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

export interface Props {
  name: string;
  text: string;
  avatar?: ImageMetadata;
}

const { name, text, avatar } = Astro.props;
---

<div class="testi-slide">
  <p class="testi-text">{text}</p>
  <span class="stars" aria-hidden="true">★★★★★</span>
  <div class="testi-person">
    {avatar && <Image class="testi-avatar" src={avatar} alt={name} width={72} height={72} loading="lazy" />}
    <span class="testi-name">{name}</span>
  </div>
</div>

<style>
  .testi-slide {
    flex: 0 0 100%;
    width: 100%;
    scroll-snap-align: start;
    text-align: center;
  }
  .testi-text {
    font-size: 0.9375rem;
    line-height: 1.85;
    color: var(--navy);
    max-width: 46ch;
    margin: 0 auto 22px;
  }
  .stars {
    color: var(--gold);
    font-size: 1.25rem;
    letter-spacing: 4px;
    margin-bottom: 16px;
    display: block;
  }
  .testi-person {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }
  .testi-person :global(.testi-avatar) {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #fff;
    box-shadow: 0 2px 10px rgba(5, 17, 69, 0.15);
  }
  .testi-name {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--navy);
  }
</style>
