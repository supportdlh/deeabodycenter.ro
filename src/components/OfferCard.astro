---
// Cardul de ofertă (secțiunea „Ofertele Deea Body Center").
// Pixel-perfect după mockup-ul V1 (mockups/v1-clona/index.html,
// blocurile .offer-card / .offer-card.tall / .offer-overlay / .btn-offer),
// în mozaic 2 coloane × 2 rânduri (primul card „tall" ocupă ambele rânduri).
// Fundalul foloseşte astro:assets <Image> poziţionat absolut (în loc de
// background-image inline) ca să beneficieze de optimizarea imaginilor.
//
// „Vezi ofertele" e un CTA de navigare (nu de programare), deci duce către
// pagina reală de ofertă (din site-inventory.md) prin `href`, la fel ca
// titlul cardului. Doar butoanele de programare rămân pe WhatsApp.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  title: string;
  excerpt: string;
  image: ImageMetadata;
  href: string;
  tall?: boolean;
}

const { title, excerpt, image, href, tall = false } = Astro.props;
---

<a href={href} class={`offer-card ${tall ? 'tall' : ''}`}>
  <Image class="offer-bg" src={image} alt="" width={640} height={640} loading="lazy" />
  <div class="offer-overlay">
    <svg class="offer-icon" viewBox="0 0 48 48" fill="none" stroke="#fff" stroke-width="1.4" aria-hidden="true">
      <path d="M24 30c-6 0-11-4-11-10 5 0 8 2 11 6 3-4 6-6 11-6 0 6-5 10-11 10Z" />
      <path d="M24 30v8" />
      <path d="M24 14c2 3 2 6 0 9-2-3-2-6 0-9Z" />
    </svg>
    <h3>{title}</h3>
    <p>{excerpt}</p>
  </div>
</a>

<style>
  .offer-card {
    position: relative;
    overflow: hidden;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 300px;
    text-decoration: none;
  }
  .offer-card.tall {
    grid-row: span 2;
    min-height: 100%;
  }
  .offer-card :global(.offer-bg) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.55s ease;
  }
  .offer-card:hover :global(.offer-bg) {
    transform: scale(1.04);
  }
  /* Tentă navy plină peste toată imaginea (ca pe live) */
  .offer-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(5, 17, 69, 0.68);
    transition: background var(--t-fast);
  }
  .offer-card:hover::after {
    background: rgba(5, 17, 69, 0.78);
  }
  .offer-overlay {
    position: relative;
    z-index: 1;
    width: 100%;
    padding: 32px 30px;
    color: #fff;
    text-align: center;
  }
  .offer-icon {
    width: 40px;
    height: 40px;
    margin: 0 auto 14px;
    display: block;
  }
  .offer-overlay h3 {
    color: #fff;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 12px;
    line-height: 1.2;
  }
  .offer-overlay p {
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.8125rem;
    line-height: 1.6;
    max-width: 34ch;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .offer-card.tall {
      grid-row: span 1;
      min-height: 260px;
    }
  }
</style>
