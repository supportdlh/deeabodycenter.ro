---
// Cardul de ofertă (secțiunea „Ofertele Deea Body Center", fundal navy).
// Portat din mockup-ul V2 aprobat (.offer-card / .offer-bg / .offer-overlay).
// Fundalul foloseşte astro:assets <Image> poziţionat absolut (în loc de
// background-image inline) ca să beneficieze de optimizarea imaginilor.
//
// „Vezi ofertele" e un CTA de navigare (nu de programare), deci duce către
// pagina reală de ofertă (din site-inventory.md) prin `href`, la fel ca
// titlul cardului. Doar butoanele de programare rămân pe WhatsApp.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  title: string;
  excerpt: string;
  image: ImageMetadata;
  href: string;
}

const { title, excerpt, image, href } = Astro.props;
---

<div class="offer-card">
  <Image class="offer-bg" src={image} alt="" width={640} height={853} loading="lazy" />
  <div class="offer-overlay"></div>
  <div class="offer-content">
    <h3><a href={href}>{title}</a></h3>
    <p>{excerpt}</p>
    <a href={href} class="btn btn-ghost">Vezi ofertele</a>
  </div>
</div>

<style>
  .offer-card {
    position: relative;
    border-radius: var(--r-md);
    overflow: hidden;
    aspect-ratio: 3 / 4;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  .offer-card :global(.offer-bg) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.55s ease;
  }
  .offer-card:hover :global(.offer-bg) {
    transform: scale(1.04);
  }
  .offer-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5, 17, 69, 0.9) 0%, rgba(5, 17, 69, 0.45) 55%, transparent 100%);
  }
  .offer-content {
    position: relative;
    padding: 32px;
  }
  .offer-content h3 {
    color: #fff;
    margin-bottom: 10px;
    font-size: 1.125rem;
  }
  .offer-content h3 a {
    color: inherit;
  }
  .offer-content h3 a:hover {
    text-decoration: underline;
  }
  .offer-content p {
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.875rem;
    line-height: 1.55;
    margin-bottom: 20px;
  }
</style>
