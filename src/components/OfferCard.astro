---
// Cardul de ofertă (secțiunea „Ofertele Deea Body Center").
// Pixel-perfect după mockup-ul V1 (mockups/v1-clona/index.html,
// blocurile .offer-card / .offer-card.tall / .offer-overlay / .btn-offer),
// în mozaic 2 coloane × 2 rânduri (primul card „tall" ocupă ambele rânduri).
// Fundalul foloseşte astro:assets <Image> poziţionat absolut (în loc de
// background-image inline) ca să beneficieze de optimizarea imaginilor.
//
// „Vezi ofertele" e un CTA de navigare (nu de programare), deci duce către
// pagina reală de ofertă (din site-inventory.md) prin `href`, la fel ca
// titlul cardului. Doar butoanele de programare rămân pe WhatsApp.
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  title: string;
  excerpt: string;
  image: ImageMetadata;
  href: string;
  tall?: boolean;
}

const { title, excerpt, image, href, tall = false } = Astro.props;
---

<a href={href} class={`offer-card ${tall ? 'tall' : ''}`}>
  <Image class="offer-bg" src={image} alt="" width={640} height={640} loading="lazy" />
  <div class="offer-overlay">
    <h3>{title}</h3>
    <p>{excerpt}</p>
    <span class="btn-offer">Vezi ofertele</span>
  </div>
</a>

<style>
  .offer-card {
    position: relative;
    overflow: hidden;
    border-radius: 10px;
    display: flex;
    align-items: flex-end;
    min-height: 260px;
    text-decoration: none;
  }
  .offer-card.tall {
    grid-row: span 2;
    min-height: 100%;
  }
  .offer-card :global(.offer-bg) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.55s ease;
  }
  .offer-card:hover :global(.offer-bg) {
    transform: scale(1.04);
  }
  .offer-overlay {
    position: relative;
    background: linear-gradient(to top, rgba(5, 17, 69, 0.85) 0%, rgba(5, 17, 69, 0.35) 60%, transparent 100%);
    width: 100%;
    padding: 24px 22px;
    color: #fff;
  }
  .offer-overlay h3 {
    color: #fff;
    font-size: 1.3125rem;
    margin-bottom: 10px;
    line-height: 1.25;
  }
  .offer-overlay p {
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.8125rem;
    line-height: 1.55;
    margin-bottom: 16px;
  }
  .btn-offer {
    display: inline-block;
    background: transparent;
    border: 2px solid #fff;
    color: #fff;
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 8px 18px;
    border-radius: 5px;
    transition:
      background var(--t-fast),
      border-color var(--t-fast);
  }
  .offer-card:hover .btn-offer {
    background: var(--magenta);
    border-color: var(--magenta);
  }

  @media (max-width: 768px) {
    .offer-card.tall {
      grid-row: span 1;
      min-height: 260px;
    }
  }
</style>
