// FAQ — identică cu cea de pe homepage (src/pages/index.astro), copiată VERBATIM de acolo.
// Pe pagina live /tarife/, blocul „Întrebări și răspunsuri" apare alături de „Trimite o
// programare" (aceeași pereche coloană-la-coloană ca pe homepage) — lipsea complet din
// pagina re-construită; restaurat aici ca conținut real, nu doar prezentare.
const faq = [
  {
    question: 'Cât durează rezultatele și de câte ședințe am nevoie pentru a vedea efecte?',
    answers: [
      'Rezultatele variază în funcție de tratament și de corpul fiecărei persoane.',
      'De obicei, se observă îmbunătățiri după 3-5 ședințe, dar pentru rezultate optime se recomandă un program complet de 6-10 ședințe, efectuate la intervale regulate.',
    ],
  },
  {
    question: 'Sunt aceste tratamente sigure și au efecte secundare?',
    answers: [
      'Tratamentele sunt sigure atunci când sunt realizate de personal instruit și cu echipamente de calitate.',
      'Pot apărea efecte secundare minore, precum roșeață sau senzație de căldură, dar acestea dispar de obicei în câteva ore.',
      'Consultăm fiecare client pentru a ne asigura că tratamentele sunt potrivite și sigure pentru el.',
    ],
  },
  {
    question: 'Cum funcționează tratamentele de slăbire/localizare a grăsimii (ex. criolipoliză, cavitație, radiofrecvență)?',
    answers: [
      'Fiecare tratament are o metodă diferită de acțiune.',
      'De exemplu, criolipoliza răcește țesutul adipos pentru a distruge celulele de grăsime, cavitația utilizează ultrasunete pentru a descompune grăsimea, iar radiofrecvența încălzește țesuturile pentru a stimula producția de colagen și a reduce celulita.',
      'Toate sunt non-invazive și nedureroase.',
    ],
  },
  {
    question: 'Ce tipuri de tratamente faciale sunt potrivite pentru tipul meu de piele?',
    answers: [
      'Oferim o consultație inițială pentru a evalua tipul de piele și nevoile specifice ale fiecărui client.',
      'În funcție de aceasta, recomandăm tratamente precum curățare profundă, hidratare intensă, anti-îmbătrânire sau pentru pielea sensibilă/acneică.',
    ],
  },
];
---

<BaseLayout
  title="Tarife - Deea Body Center"
  description="Tarifele accesibile pentru tratamente faciale și corporale la Deea Body Center Ploiești! Soluții personalizate pentru un look sănătos și revitalizat."
  canonicalPath="/tarife/"
>
  <!-- =========================================================
       INNER HERO (bandă gri-deschis) — replică live /tarife/
  ========================================================== -->
  <InnerHero
    title="Tarife tratamente corporale si faciale"
    breadcrumb={[{ label: 'Tarife' }]}
    image="/top-oferte.jpg"
    imageAlt="Tarife tratamente corporale și faciale — Deea Body Center"
  />

  <!-- =========================================================
       INTRO (paragraf navy + paragraf cu clauză teal) + social
  ========================================================== -->
  <section class="intro">
    <div class="wrap">
      <p class="intro-lead">
        Descoperă la Deea Body Center soluții complete pentru un ten luminos și un corp remodelat, cu rezultate spectaculoase.
      </p>
      <p class="intro-lead">
        <a class="intro-teal" href="/tarife/">Tarifele accesibile pentru tratamente faciale și corporale</a>{' '}
        la Deea Body Center Ploiești! Soluții personalizate pentru un look sănătos și revitalizat.
      </p>
      <div class="intro-social">
        <a href={site.social.facebook || '#'} aria-label="Facebook">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
            ><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg
          >
        </a>
        <a href={site.social.instagram || '#'} aria-label="Instagram">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
            ><rect x="2" y="2" width="20" height="20" rx="5"></rect><path
              d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"
            ></line></svg
          >
        </a>
      </div>
    </div>
  </section>

  <!-- =========================================================
       LISTE DE TARIFE
  ========================================================== -->
  <section class="section">
    <div class="wrap">
      <div class="price-group">
        <h2>Tratamente Hera</h2>
        {
          heraSubgroups.map((sub) => (
            <div class="hera-sub">
              <h3>{sub.subtitle}</h3>
              <ul class="price-list">
                {sub.items.map((item) => (
                  <li class="price-row hera-row">
                    <div class="hera-main">
                      <span class="price-name">{item.name}</span>
                      <span class="price-leader" aria-hidden="true" />
                      <span class="price-value">{item.price}</span>
                    </div>
                    {item.detail && <p class="price-detail">{item.detail}</p>}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
      {
        groups.map((group) => (
          <div class="price-group">
            <h2>{group.title}</h2>
            <ul class="price-list">
              {group.items.map((item) => (
                <li class="price-row">
                  <span class="price-name">{item.name}</span>
                  <span class="price-leader" aria-hidden="true" />
                  <span class="price-value">{item.price}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <!-- =========================================================
       CTA — PROGRAMARE WHATSAPP (fără formular) + FAQ
       (pereche coloană-la-coloană, identică structurii de pe pagina live
       /tarife/ și pe homepage — vezi src/pages/index.astro)
  ========================================================== -->
  <section class="section--alt contact-faq-section" id="programare">
    <div class="wrap contact-grid">
      <ContactBlock />

      <div class="faq-col">
        <h2>Întrebări și răspunsuri</h2>
        <p class="faq-sub">Răspunsuri la cele mai frecvente întrebări pe care le primim din partea clienților.</p>
        <div class="accordion">
          {
            faq.map((item) => (
              <Accordion title={item.question}>
                {item.answers.map((a) => (
                  <p>{a}</p>
                ))}
              </Accordion>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .wrap {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 15px;
  }

  /* ===== INTRO (sub bandă hero) ===== */
  .intro {
    background: var(--surface);
    padding: 28px 0 8px;
  }
  .intro .wrap {
    max-width: 1140px;
  }
  .intro-lead {
    color: var(--navy, #051145);
    font-size: 1.0625rem;
    line-height: 1.7;
    max-width: 640px;
    margin: 0 0 14px;
  }
  .intro-teal {
    color: var(--teal, #148a87);
    text-decoration: none;
  }
  .intro-teal:hover {
    text-decoration: underline;
  }
  .intro-social {
    display: flex;
    gap: 14px;
    margin-top: 22px;
  }
  .intro-social a {
    color: var(--navy, #051145);
    display: inline-flex;
    transition: color 0.2s ease;
  }
  .intro-social a:hover {
    color: var(--teal, #148a87);
  }

  /* ===== PRICE LISTS ===== */
  .section {
    padding: 40px 0 80px;
    background: var(--surface);
  }
  .section--alt {
    padding: 72px 0;
    background: var(--surface-alt);
  }

  .price-group {
    margin-bottom: 52px;
  }
  .price-group:last-child {
    margin-bottom: 0;
  }
  .price-group h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 1.75rem;
    color: var(--navy, #051145);
    margin-bottom: 24px;
  }

  /* ===== Subcategorii „Tratamente Hera" (h3 teal) + rând cu durată ===== */
  .hera-sub {
    margin-bottom: 30px;
  }
  .hera-sub:last-child {
    margin-bottom: 0;
  }
  .hera-sub h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--teal, #148a87);
    margin: 0 0 6px;
  }
  /* Rândul Hera: linia nume ...... preț, plus o linie de detaliu (durată) sub ea.
     Selector cu specificitate dublă ca să învingă `.price-row { align-items: center }`
     definit mai jos în foaia de stil. */
  .price-row.hera-row {
    flex-direction: column;
    align-items: stretch;
    gap: 2px;
    padding: 12px 0;
  }
  .hera-main {
    display: flex;
    align-items: flex-end;
    gap: 0;
  }
  .price-detail {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.45;
    color: var(--text-sec);
    max-width: 760px;
  }

  /* Single full-width column with dotted-leader lines (name ..... price) */
  .price-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: block;
  }
  .price-row {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 14px 0;
  }
  .price-name {
    font-size: 1.1875rem;
    font-weight: 600;
    color: var(--navy, #051145);
    line-height: 1.4;
  }
  .price-leader {
    flex: 1 1 auto;
    align-self: flex-end;
    margin: 0 10px 6px;
    border-bottom: 1px dashed var(--navy, #051145);
    min-width: 24px;
  }
  .price-value {
    flex-shrink: 0;
    font-weight: 600;
    font-size: 1.1875rem;
    color: var(--navy, #051145);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  /* ===== CONTACT + FAQ ===== */
  .contact-faq-section .wrap {
    max-width: 1170px;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
  }
  .faq-col h2 {
    font-size: 1.875rem;
    margin-bottom: 10px;
  }
  .faq-sub {
    font-size: 0.875rem;
    color: var(--text-sec);
    margin-bottom: 22px;
    line-height: 1.6;
  }
  .accordion {
    display: flex;
    flex-direction: column;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .section {
      padding: 32px 0 56px;
    }
    .section--alt {
      padding: 48px 0;
    }
    .price-group h2 {
      font-size: 1.5rem;
    }
    .price-name,
    .price-value {
      font-size: 1rem;
    }
  }
  @media (max-width: 640px) {
    .wrap {
      padding: 0 20px;
    }
    .price-name {
      font-size: 0.9375rem;
    }
    .price-value {
      font-size: 0.9375rem;
    }
  }
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
