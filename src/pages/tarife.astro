// fiecare intrare având și durata/ședința (detail). Prețuri normalizate la „RON"
// pentru a fi consecvente cu restul paginii (clientul le-a scris ca „lei").
interface HeraItem {
  name: string;
  price: string;
  detail?: string;
}
interface HeraSubgroup {
  subtitle: string;
  items: HeraItem[];
}

