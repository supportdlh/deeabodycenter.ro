---
// Pagină unică „Tarife" — slug exact din reference/site-inventory.md (/tarife/).
// Conținut PORTAT FIDEL din pagina live (https://deeabodycenter.ro/tarife/, curl 2026-07-05),
// verificat linie cu linie prin grep pe HTML brut — NICIUN preț/serviciu inventat.
// Listele de mai jos păstrează VERBATIM textul sursă (inclusiv absența diacriticelor pe
// unele intrări, ex. „sedinte", „faciala" — așa cum apare literal pe site-ul live), tocmai
// pentru a elimina orice ambiguitate/interpretare asupra unei pagini de preț.
import BaseLayout from '../layouts/BaseLayout.astro';
import InnerHero from '../components/InnerHero.astro';
import ContactBlock from '../components/ContactBlock.astro';
import Accordion from '../components/Accordion.astro';
import { site } from '../data/site';

interface PriceItem {
  name: string;
  price: string;
}

interface PriceGroup {
