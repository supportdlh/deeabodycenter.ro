import imgVelaShape from '../assets/vela-shape-deeabocycenter-ploiesti_DBC-203.webp';
import imgCriolipoliza from '../assets/criolipoliza-cryogen-deeabocycenter-ploiesti_DBC-428.webp';
import imgElectrostimulare from '../assets/slabire-electrostimulare-deeabocycenter-ploiesti_DBC-271.webp';
import imgPresoterapie from '../assets/presoterapie-deeabodycenter-ploiesti.png';
import imgSolar from '../assets/solar-deeabocycenter-ploiesti_DBC-297.webp';
import imgEpilare from '../assets/epilare-definitiva-cu-laser-deeabodycenter-ploiesti.jpg';

import imgOfferCorporal from '../assets/oferte-deea-body-center-ploiesti.webp';
import imgOfferSpeciale from '../assets/DSC00993-scaled.webp';
import imgOfferFaciale from '../assets/Tratament-sculptor-deeabodycenter.ro-ploiesti.webp';

import imgTestimonialsBg from '../assets/testimonials.webp';

const facialCards = [
  {
    title: 'Intraceuticals',
    excerpt:
      'Rezultate spectaculoase in tratarea ridurilor, pielii imbatranite, acnee, pete pigmentare, cearcane, elasticitate si volum piele.',
