    image: imgGreenPeel,
    href: '/tratament-green-peel-by-dr-schrammek/',
  },
  {
    title: 'Tratament HidratIQ',
    excerpt:
      'Combina cosmetica 7 functii: Aqua peel, Oxigen Hiperbaric, Radiofrecventa, Ultrasunete, Spatula Ultrasunet, Ionoforeza, CrioHeat.',
    image: imgHidratiq,
    href: '/tratament-hidratiq/',
  },
