---
// Homepage — reskinned pixel-perfect după mockup-ul V1 aprobat
// (mockups/v1-clona/index.html), folosind BaseLayout + componentele
// comune (Header/Footer prin BaseLayout) + WhatsAppButton +
// componentele (ServiceCard/OfferCard/TestimonialCard/Accordion/ContactBlock).
// Copy exact din reference/content.md; meta din reference/design-tokens.md.
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import ServiceCard from '../components/ServiceCard.astro';
import OfferCard from '../components/OfferCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import Accordion from '../components/Accordion.astro';
import ContactBlock from '../components/ContactBlock.astro';
import LocalBusinessSchema from '../components/schema/LocalBusinessSchema.astro';
import { site } from '../data/site';

import heroImg from '../assets/promo-remodelare-corporala.webp';
import facialSplitImg from '../assets/DSC01046-1536x1024.webp';
import bodySplitImg from '../assets/DSC00993-scaled.webp';

import imgIntraceuticals from '../assets/tratament-intraceuticals-deeabocycenter-ploiesti_DBC-542.webp';
import imgOptiFirm from '../assets/tratamente-faciale-1.png';
import imgRf4k from '../assets/woman-rf-skin-tightening-min-1536x1008-1.webp';
