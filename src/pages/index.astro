    href: '/tratament-facial-intraceuticals/',
  },
  {
    title: 'Tratament special pentru ochi OPTI-FIRM',
    excerpt:
      'Tratament special pentru ochi OPTI-FIRM eye contour REPECHAGE – pentru cearcane, riduri si pungile de sub ochi.',
    image: imgOptiFirm,
    href: '/tratament-opti-firm/',
  },
  {
    title: 'Tratamentul facial cu Radiofrecvență 4K',
    excerpt:
      'Recomandată pentru oricine dorește o piele mai fermă, mai netedă și cu un aspect întinerit, fără disconfort și fără intervenții invazive.',
    image: imgRf4k,
    href: '/tratament-facial-cu-radiofrecventa-4k/',
  },
  {
    title: 'Tratament facial MicroPen',
