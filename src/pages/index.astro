    href: '/presoterapie/',
  },
  {
    title: 'Solar',
    excerpt: 'Va doriti un look exotic cu o piele perfect bronzata fara sa va expuneţi la soare?',
    image: imgSolar,
    href: '/solar/',
  },
  {
    title: 'Epilarea definitivă cu laserul XLight',
    excerpt: 'Reprezintă o soluție avansată și eficientă pentru îndepărtarea permanentă a părului nedorit.',
