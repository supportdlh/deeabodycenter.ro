const offerCards = [
  {
    title: 'Oferte Tratamente Remodelare Corporala',
    excerpt: 'Tratamente corporale personalizate care tonifiază, sculptează și reduc celulita, cu rezultate vizibile și de durată.',
    image: imgOfferCorporal,
    href: '/oferte-tratamente-corporale/',
    tall: true,
  },
  {
    title: 'Oferte speciale',
    excerpt: 'Oferte speciale pentru tratamente faciale și corporale, obținând un ten luminos și un corp tonifiat.',
    image: imgOfferSpeciale,
    href: '/oferte-speciale-tratamente-faciale-si-corporale/',
  },
  {
    title: 'Oferte Tratamente Faciale',
    excerpt: 'Tratamentele faciale personalizează îngrijirea tenului tău, oferind hidratare intensă și regenerare celulară.',
    image: imgOfferFaciale,
    href: '/oferte-tratamente-faciale/',
  },
];

const testimonials = [
  {
    name: 'Maria, 35 de ani',
    text: 'Sunt absolut încântată de rezultatele obținute la Deea Body Center! Am început cu ședințe de remodelare corporală și am văzut diferențe vizibile încă de la primele tratamente. Pielea mea e mai fermă, iar centimetrii din talie și coapse s-au redus semnificativ. Echipa este profesionistă și amabilă, iar atmosfera este relaxantă. Recomand cu toată încrederea!',
  },
  {
    name: 'Andreea, 29 de ani',
    text: 'Tratamentele faciale de la Deea Body Center mi-au schimbat complet tenul! Am avut probleme cu cearcănele și ridurile fine, iar după câteva ședințe de radiofrecvență și tratamente hidratante, pielea mea e mai luminoasă și vizibil întinerită. Recomand acest loc minunat oricărei femei care își dorește un boost de încredere și frumusețe!',
  },
  {
    name: 'Elena, 42 de ani',
    text: 'De când am descoperit Deea Body Center, am început o transformare pe care o așteptam de mult. Remodelarea corporală mi-a tonifiat corpul, iar tratamentele faciale m-au ajutat să am un ten mult mai neted și radiant. Profesionalismul și atenția la detalii de aici sunt de neegalat! Este locul ideal pentru momente de răsfăț și îngrijire completă.',
  },
];

// Răspunsuri REALE, extrase din accordion-ul live (deeabodycenter.ro, 2026-07-05) —
// diferă de textul generic din mockup-ul V2 (care conținea variante placeholder).
const faq = [
  {
    question: 'Cât durează rezultatele și de câte ședințe am nevoie pentru a vedea efecte?',
    answers: [
      'Rezultatele variază în funcție de tratament și de corpul fiecărei persoane.',
      'De obicei, se observă îmbunătățiri după 3-5 ședințe, dar pentru rezultate optime se recomandă un program complet de 6-10 ședințe, efectuate la intervale regulate.',
    ],
  },
  {
    question: 'Sunt aceste tratamente sigure și au efecte secundare?',
    answers: [
      'Tratamentele sunt sigure atunci când sunt realizate de personal instruit și cu echipamente de calitate.',
      'Pot apărea efecte secundare minore, precum roșeață sau senzație de căldură, dar acestea dispar de obicei în câteva ore.',
      'Consultăm fiecare client pentru a ne asigura că tratamentele sunt potrivite și sigure pentru el.',
    ],
  },
  {
    question: 'Cum funcționează tratamentele de slăbire/localizare a grăsimii (ex. criolipoliză, cavitație, radiofrecvență)?',
    answers: [
      'Fiecare tratament are o metodă diferită de acțiune.',
      'De exemplu, criolipoliza răcește țesutul adipos pentru a distruge celulele de grăsime, cavitația utilizează ultrasunete pentru a descompune grăsimea, iar radiofrecvența încălzește țesuturile pentru a stimula producția de colagen și a reduce celulita.',
      'Toate sunt non-invazive și nedureroase.',
    ],
  },
  {
    question: 'Ce tipuri de tratamente faciale sunt potrivite pentru tipul meu de piele?',
    answers: [
      'Oferim o consultație inițială pentru a evalua tipul de piele și nevoile specifice ale fiecărui client.',
      'În funcție de aceasta, recomandăm tratamente precum curățare profundă, hidratare intensă, anti-îmbătrânire sau pentru pielea sensibilă/acneică.',
    ],
  },
];
---

<BaseLayout
  title="Deea Body Center - Remodelare corporala si tratamente faciale"
  description="Obține silueta dorită cu tratamentele de remodelare corporala de la Deea Body Center Ploiești. Tonifiere, reducerea celulitei și contur perfect!"
  canonicalPath="/"
>
  <Fragment slot="head">
    <LocalBusinessSchema />
  </Fragment>

  <!-- ============================================================
       HERO — „Ofertă limitată" (layout original, fără float/scale)
  ============================================================= -->
  <section class="hero">
    <div class="wrap hero-inner">
      <div class="hero-content">
        <span class="eyebrow">Ofertă limitată</span>
        <h1 class="hero-title">
          Transformă-ți corpul și redefinește-ți încrederea cu oferta noastră exclusivă de remodelare!
        </h1>
        <p class="hero-desc">Rezervă acum pachetul tău complet și profită de criolipoliza cadou!</p>
        <ul class="hero-list">
          <li>3 ședințe VelaShape – coapse + fese</li>
          <li>2 ședințe VelaShape – abdomen + flancuri + lombar</li>
          <li>3 ședințe laser Zentisse</li>
          <li>3 ședințe presodrenaj</li>
          <li>1 zonă mare de criolipoliză <strong>cadou</strong></li>
        </ul>
        <div class="hero-price">1690 RON</div>
        <p class="hero-note">Nu rata șansa de a obține silueta mult dorită la un preț special!</p>
        <div class="social-row hero-social">
          <a href={site.social.facebook || '#'} class="social-icon" aria-label="Facebook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
              ><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg
            >
          </a>
          <a href={site.social.instagram || '#'} class="social-icon" aria-label="Instagram">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><rect x="2" y="2" width="20" height="20" rx="5"></rect><path
                d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"
              ></line></svg
            >
          </a>
        </div>
        <WhatsAppButton
          label="Programează-te"
          message="Bună, aș dori să profit de oferta cu criolipoliza cadou (pachet 1690 RON)."
          class="hero-cta"
        />
      </div>
      <div class="hero-image">
        <Image
          src={heroImg}
          alt="Pachet remodelare corporală — criolipoliză cadou"
          width={800}
          height={800}
          widths={[400, 600, 800]}
          sizes="(max-width: 768px) 90vw, 520px"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- ============================================================
       TRATAMENTE FACIALE — intro (imagine + text)
  ============================================================= -->
  <section class="section-intro" id="tratamente-faciale">
    <div class="wrap intro-grid">
      <div class="intro-img-wrap">
        <Image
          class="intro-img"
          src={facialSplitImg}
          alt="Tratamente faciale Deea Body Center Ploiești"
          width={800}
          height={600}
          widths={[400, 600, 800]}
          sizes="(max-width: 768px) 90vw, 560px"
          loading="lazy"
        />
      </div>
      <div class="intro-text">
        <span class="eyebrow">Deea Body Center</span>
        <h2>Tratamente Faciale</h2>
        <p>
          Ten revitalizat, neted și luminos, cu tratamente faciale personalizate pentru un aspect proaspăt și
          sănătos, fără imperfecțiuni.
        </p>
        <div class="btn-row">
          <a href="/servicii-tratamente-faciale-si-corporale/" class="btn btn-primary">Descoperă</a>
          <a href="/tarife/" class="btn btn-outline">Tarife</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       BANDA „Tenul pe care ți-l dorești" + grid (6 carduri)
  ============================================================= -->
  <section class="services-band">
    <div class="wrap">
      <span class="eyebrow">Deea Body Center</span>
      <h2>Tenul pe care ți-l dorești, la un pas distanță!</h2>
      <p>La Deea Body Center, obții un ten radiant prin tratamente faciale personalizate, cu rezultate vizibile.</p>
    </div>
  </section>
  <section class="cards-section">
    <div class="wrap">
      <div class="svc-grid">
        {facialCards.map((card) => <ServiceCard {...card} />)}
      </div>
    </div>
  </section>

  <!-- ============================================================
       REMODELARE CORPORALA — intro (text + imagine)
  ============================================================= -->
  <section class="section-intro bg-offwhite">
    <div class="wrap intro-grid">
      <div class="intro-text">
        <span class="eyebrow">Deea Body Center</span>
        <h2>Remodelare corporala</h2>
        <p>
          Tratamente de remodelare corporala prin reducerea grăsimii localizate, eliminarea celulitei, tonifierea
          pielii și îmbunătățirea conturului corporal, oferind rezultate rapide și fără intervenții chirurgicale.
        </p>
        <div class="btn-row">
          <a href="/servicii-tratamente-faciale-si-corporale/" class="btn btn-primary">Descoperă</a>
          <a href="/tarife/" class="btn btn-outline">Tarife</a>
        </div>
      </div>
      <div class="intro-img-wrap">
        <Image
          class="intro-img"
          src={bodySplitImg}
          alt="Remodelare corporală Deea Body Center Ploiești"
          width={800}
          height={600}
          widths={[400, 600, 800]}
          sizes="(max-width: 768px) 90vw, 560px"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ============================================================
       BANDA „Corpul pe care ți-l dorești" + grid (9 carduri)
  ============================================================= -->
  <section class="services-band">
    <div class="wrap">
      <span class="eyebrow">Deea Body Center</span>
      <h2>Corpul pe care ți-l dorești, la un pas distanță!</h2>
      <p>La Deea Body Center, obții un corp tonifiat prin tratamente corporale personalizate, cu rezultate vizibile.</p>
    </div>
  </section>
  <section class="cards-section">
    <div class="wrap">
      <div class="svc-grid">
        {bodyCards.map((card) => <ServiceCard {...card} />)}
      </div>
    </div>
  </section>

  <!-- ============================================================
       SOLAR
  ============================================================= -->
  <section class="solar-section">
    <div class="solar-inner">
      <span class="eyebrow">Deea Body Center</span>
      <h2>Solar</h2>
      <p>
        Va doriţi un look exotic cu o piele perfect bronzata fara sa va expuneţi la soare? Deea Body Center va
        propune o solutie rapida si eficienta: solariile ERGOLINE – lider incontestabil in domeniilor solariilor.
      </p>
      <div class="btn-row">
        <a href="/solar/" class="btn btn-primary">Descoperă</a>
        <a href="/tarife/" class="btn btn-outline">Tarife</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       OFERTE
  ============================================================= -->
  <section class="offers-section">
    <div class="wrap">
      <h2 class="offers-title">Ofertele Deea Body Center</h2>
    </div>
    <div class="offers-mosaic">
      {offerCards.map((card) => <OfferCard {...card} />)}
    </div>
  </section>

  <!-- ============================================================
       TESTIMONIALE „Ce spun ele"
  ============================================================= -->
  <section class="testi-section">
    <div class="testi-bg-wrap" role="presentation">
      <Image class="testi-bg-img" src={imgTestimonialsBg} alt="" width={1920} height={1277} loading="lazy" />
      <div class="testi-overlay"></div>
    </div>
    <div class="wrap testi-inner">
      <h2 class="testi-heading">Ce spun ele</h2>
      <div class="testi-grid">
        {testimonials.map((t) => <TestimonialCard {...t} />)}
      </div>
    </div>
  </section>

  <!-- ============================================================
       CONTACT & FAQ
  ============================================================= -->
  <section class="contact-faq-section" id="programare">
    <div class="wrap contact-grid">
      <ContactBlock />

      <div class="faq-col">
        <h2>Întrebări și răspunsuri</h2>
        <p class="faq-sub">Răspunsuri la cele mai frecvente întrebări pe care le primim din partea clienților.</p>
        <div class="accordion">
          {
            faq.map((item) => (
              <Accordion title={item.question}>
                {item.answers.map((a) => (
                  <p>{a}</p>
                ))}
              </Accordion>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .wrap {
    max-width: 1170px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.155em;
    text-transform: uppercase;
    color: var(--teal);
    display: block;
    margin-bottom: 10px;
  }

  .btn-row {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  /* ===== HERO ===== */
  .hero {
    background: linear-gradient(130deg, #ded1f2 0%, #eae1f5 25%, #f2edf9 50%, #f8f4fc 72%, #ffffff 100%);
    position: relative;
    overflow: hidden;
    padding: 56px 0 48px;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -120px;
    right: 320px;
    width: 480px;
    height: 480px;
    background: radial-gradient(circle, rgba(167, 64, 143, 0.07) 0%, transparent 65%);
    border-radius: 50%;
    pointer-events: none;
  }
  .hero::after {
    content: '';
    position: absolute;
    bottom: -80px;
    left: -60px;
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, rgba(28, 114, 97, 0.05) 0%, transparent 65%);
    border-radius: 50%;
    pointer-events: none;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--heading);
    line-height: 1.22;
    margin-bottom: 14px;
  }
  .hero-desc {
    font-size: 0.9375rem;
    color: var(--text-sec);
    margin-bottom: 18px;
  }

  .hero-list {
    list-style: none;
    margin-bottom: 22px;
  }
  .hero-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.90625rem;
    color: var(--heading);
    margin-bottom: 9px;
    line-height: 1.5;
  }
  .hero-list li::before {
    content: '';
    display: inline-block;
    width: 14px;
    height: 14px;
    min-width: 14px;
    min-height: 14px;
    background: var(--gold);
    border-radius: 50%;
    margin-top: 3px;
  }

  .hero-price {
    font-family: 'Playfair Display', serif;
    font-size: 3.375rem;
    font-weight: 700;
    color: var(--magenta);
    line-height: 1.1;
    margin-bottom: 10px;
  }
  .hero-note {
    font-size: 0.875rem;
    color: var(--text-sec);
    font-style: italic;
    margin-bottom: 20px;
  }

  .hero-social {
    margin-bottom: 22px;
  }
