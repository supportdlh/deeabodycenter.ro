// Răspunsuri REALE, extrase din accordion-ul live (deeabodycenter.ro, 2026-07-05) —
// diferă de textul generic din mockup-ul V2 (care conținea variante placeholder).
const faq = [
  {
    question: 'Cât durează rezultatele și de câte ședințe am nevoie pentru a vedea efecte?',
    answers: [
      'Rezultatele variază în funcție de tratament și de corpul fiecărei persoane.',
      'De obicei, se observă îmbunătățiri după 3-5 ședințe, dar pentru rezultate optime se recomandă un program complet de 6-10 ședințe, efectuate la intervale regulate.',
    ],
  },
  {
    question: 'Sunt aceste tratamente sigure și au efecte secundare?',
    answers: [
      'Tratamentele sunt sigure atunci când sunt realizate de personal instruit și cu echipamente de calitate.',
      'Pot apărea efecte secundare minore, precum roșeață sau senzație de căldură, dar acestea dispar de obicei în câteva ore.',
      'Consultăm fiecare client pentru a ne asigura că tratamentele sunt potrivite și sigure pentru el.',
    ],
  },
  {
    question: 'Cum funcționează tratamentele de slăbire/localizare a grăsimii (ex. criolipoliză, cavitație, radiofrecvență)?',
    answers: [
      'Fiecare tratament are o metodă diferită de acțiune.',
      'De exemplu, criolipoliza răcește țesutul adipos pentru a distruge celulele de grăsime, cavitația utilizează ultrasunete pentru a descompune grăsimea, iar radiofrecvența încălzește țesuturile pentru a stimula producția de colagen și a reduce celulita.',
      'Toate sunt non-invazive și nedureroase.',
    ],
  },
  {
    question: 'Ce tipuri de tratamente faciale sunt potrivite pentru tipul meu de piele?',
    answers: [
      'Oferim o consultație inițială pentru a evalua tipul de piele și nevoile specifice ale fiecărui client.',
      'În funcție de aceasta, recomandăm tratamente precum curățare profundă, hidratare intensă, anti-îmbătrânire sau pentru pielea sensibilă/acneică.',
    ],
  },
];
---

<BaseLayout
  title="Deea Body Center - Remodelare corporala si tratamente faciale"
  description="Obține silueta dorită cu tratamentele de remodelare corporala de la Deea Body Center Ploiești. Tonifiere, reducerea celulitei și contur perfect!"
  canonicalPath="/"
>
  <Fragment slot="head">
    <LocalBusinessSchema />
  </Fragment>

  <!-- ============================================================
       HERO — „Ofertă limitată" (layout original, fără float/scale)
  ============================================================= -->
  <section class="hero">
    <div class="wrap hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">✨ Ofertă Specială</p>
        <h1 class="hero-title">Pachet HERA — 7 ședințe la un preț de excepție! 🤍</h1>
        <ul class="hero-list">
          <li>7 ședințe personalizate HERA</li>
          <li>Remodelare corporală și tonifiere</li>
          <li>Reducerea aspectului de celulită</li>
          <li>Piele mai fermă și mai netedă</li>
          <li>Plan adaptat obiectivelor tale</li>
        </ul>
        <div class="hero-price-block">
          <p class="hero-price-value">💎 Valoare pachet: <span class="hero-price-old">2.800 lei</span></p>
          <div class="hero-price">🔥 2.100 RON</div>
          <p class="hero-price-economy">🎁 Economisești 700 lei!</p>
        </div>
        <WhatsAppButton
          label="Vreau Pachetul HERA"
          message="Bună, aș dori să profit de Pachetul HERA – 7 ședințe la 2.100 lei. Când pot programa prima ședință?"
          class="hero-cta"
        />
      </div>
      <div class="hero-image">
        <div class="hera-poster">
          <Image
            class="hera-poster-photo"
            src={heroImg}
            alt="Tratament HERA remodelare corporală — Pachet 7 ședințe"
            width={800}
            height={800}
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 90vw, 598px"
            loading="eager"
          />
          <div class="hera-poster-overlay">
            <div class="hera-poster-badge">✨ OFERTĂ SPECIALĂ ✨</div>
            <div class="hera-poster-title">
              <span class="hera-poster-pachet">PACHET</span>
              <span class="hera-poster-hera">HERA</span>
              <span class="hera-poster-sub">Corporal</span>
            </div>
            <div class="hera-poster-benefits">
              <div class="hera-poster-ben"><span>✦</span> 7 ședințe personalizate</div>
              <div class="hera-poster-ben"><span>✦</span> Remodelare corporală &amp; tonifiere</div>
              <div class="hera-poster-ben"><span>✦</span> Reducere aspect celulită</div>
              <div class="hera-poster-ben"><span>✦</span> Piele mai fermă și mai netedă</div>
              <div class="hera-poster-ben"><span>✦</span> Plan adaptat obiectivelor tale</div>
            </div>
            <div class="hera-poster-price-row">
              <div class="hera-poster-price-box">
                <div class="hera-poster-price-lbl">PREȚ</div>
                <div class="hera-poster-price-line"></div>
                <div class="hera-poster-price-num">2.100</div>
                <div class="hera-poster-price-line"></div>
                <div class="hera-poster-price-curr">LEI</div>
              </div>
              <div class="hera-poster-price-info">
                <div class="hera-poster-price-sessions">7 ședințe HERA</div>
                <div class="hera-poster-price-old">Valoare: 2.800 lei</div>
                <div class="hera-poster-price-eco">🎁 Economisești 700 lei!</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Divizor ondulat (val) — identic ca formă cu shape-divider-ul din live (elementor-shape-bottom) -->
    <div class="hero-wave" aria-hidden="true">
      <svg viewBox="0 0 1000 100" preserveAspectRatio="none">
        <path
          d="M473,67.3c-203.9,88.3-263.1-34-320.3,0C66,119.1,0,59.7,0,59.7V0h1000v59.7 c0,0-62.1,26.1-94.9,29.3c-32.8,3.3-62.8-12.3-75.8-22.1C806,49.6,745.3,8.7,694.9,4.7S492.4,59,473,67.3z"
          fill="#ffffff"
          opacity="0.33"></path>
        <path
          d="M734,67.3c-45.5,0-77.2-23.2-129.1-39.1c-28.6-8.7-150.3-10.1-254,39.1 s-91.7-34.4-149.2,0C115.7,118.3,0,39.8,0,39.8V0h1000v36.5c0,0-28.2-18.5-92.1-18.5C810.2,18.1,775.7,67.3,734,67.3z"
          fill="#ffffff"
          opacity="0.66"></path>
        <path
          d="M766.1,28.9c-200-57.5-266,65.5-395.1,19.5C242,1.8,242,5.4,184.8,20.6C128,35.8,132.3,44.9,89.9,52.5C28.6,63.7,0,0,0,0 h1000c0,0-9.9,40.9-83.6,48.1S829.6,47,766.1,28.9z"
          fill="#ffffff"
          opacity="1"></path>
      </svg>
    </div>
  </section>

  <!-- ============================================================
       TRATAMENTE FACIALE — intro (imagine + text)
  ============================================================= -->
  <section class="section-intro" id="tratamente-faciale">
    <div class="wrap intro-grid">
      <div class="intro-img-wrap has-frame">
        <span class="deco-square" aria-hidden="true"></span>
        <Image
          class="intro-img intro-img-poster"
          src={facialSplitImg}
          alt="Tratamente faciale Deea Body Center Ploiești"
          width={1254}
          height={1254}
          widths={[600, 900, 1254]}
          sizes="(max-width: 768px) 90vw, 560px"
          loading="lazy"
        />
      </div>
      <div class="intro-text">
        <span class="deco-dots" aria-hidden="true"></span>
        <span class="eyebrow">Deea Body Center</span>
        <h2>Tratamente Faciale</h2>
        <p>
          Ten revitalizat, neted și luminos, cu tratamente faciale personalizate pentru un aspect proaspăt și
          sănătos, fără imperfecțiuni.
        </p>
        <div class="btn-row">
          <a href="/servicii-tratamente-faciale-si-corporale/" class="btn btn-primary">Descoperă</a>
          <a href="/tarife/" class="btn btn-primary">Tarife</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       BANDA „Tenul pe care ți-l dorești" + grid (6 carduri)
  ============================================================= -->
  <section class="services-band">
    <div class="wrap">
      <span class="eyebrow">Deea Body Center</span>
      <h2>Tenul pe care ți-l dorești, la un pas distanță!</h2>
      <p>La Deea Body Center, obții un ten radiant prin tratamente faciale personalizate, cu rezultate vizibile.</p>
    </div>
  </section>
  <section class="cards-section">
    <div class="wrap">
      <div class="svc-grid">
        {facialCards.map((card) => <ServiceCard {...card} />)}
      </div>
    </div>
  </section>

  <!-- ============================================================
       REMODELARE CORPORALA — intro (text + imagine)
  ============================================================= -->
  <section class="section-intro bg-offwhite">
    <div class="wrap intro-grid">
      <div class="intro-text">
        <span class="eyebrow">Deea Body Center</span>
        <h2>Remodelare corporala</h2>
        <p>
          Tratamente de remodelare corporala prin reducerea grăsimii localizate, eliminarea celulitei, tonifierea
          pielii și îmbunătățirea conturului corporal, oferind rezultate rapide și fără intervenții chirurgicale.
        </p>
        <div class="btn-row">
          <a href="/servicii-tratamente-faciale-si-corporale/" class="btn btn-primary">Descoperă</a>
          <a href="/tarife/" class="btn btn-primary">Tarife</a>
        </div>
      </div>
      <div class="intro-img-wrap intro-img-right">
        <span class="deco-dots deco-dots-left" aria-hidden="true"></span>
        <Image
          class="intro-img intro-img-poster"
          src={imgHeraPromo}
          alt="tratament HERA 120 de minute — abdomen, coapse 360°, fese, 650 RON la Deea Body Center Ploiesti"
          width={1254}
          height={1254}
          widths={[600, 900, 1254]}
          sizes="(max-width: 768px) 90vw, 560px"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ============================================================
       BANDA „Corpul pe care ți-l dorești" + grid (9 carduri)
  ============================================================= -->
  <section class="services-band">
    <div class="wrap">
      <span class="eyebrow">Deea Body Center</span>
      <h2>Corpul pe care ți-l dorești, la un pas distanță!</h2>
      <p>La Deea Body Center, obții un corp tonifiat prin tratamente corporale personalizate, cu rezultate vizibile.</p>
    </div>
  </section>
  <section class="cards-section">
    <div class="wrap">
      <div class="svc-grid">
        {bodyCards.map((card) => <ServiceCard {...card} />)}
      </div>
    </div>
  </section>

  <!-- ============================================================
       SOLAR
  ============================================================= -->
  <section class="section-intro solar-section">
    <div class="wrap intro-grid">
      <div class="intro-text">
        <span class="eyebrow">Deea Body Center</span>
        <h2>Solar</h2>
        <p>
          Va doriţi un look exotic cu o piele perfect bronzata fara sa va expuneţi la soare? Deea Body Center va
          propune o solutie rapida si eficienta: solariile ERGOLINE – lider incontestabil in domeniilor solariilor.
        </p>
        <div class="btn-row">
          <a href="/solar/" class="btn btn-primary">Descoperă</a>
          <a href="/tarife/" class="btn btn-primary">Tarife</a>
        </div>
      </div>
      <div class="intro-img-wrap intro-img-right">
        <span class="deco-dots deco-dots-left" aria-hidden="true"></span>
        <Image
          class="intro-img"
          src={imgSolar}
          alt="Solar Ergoline la Deea Body Center Ploiești"
          width={800}
          height={600}
          widths={[400, 600, 800]}
          sizes="(max-width: 768px) 90vw, 560px"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ============================================================
       OFERTE
  ============================================================= -->
  <section class="offers-section">
    <span class="deco-square offers-deco" aria-hidden="true"></span>
    <div class="wrap">
      <span class="eyebrow offers-eyebrow">Deea Body Center</span>
      <h2 class="offers-title">Ofertele Deea Body Center</h2>
    </div>
    <div class="offers-mosaic">
      {offerCards.map((card) => <OfferCard {...card} />)}
    </div>
  </section>

  <!-- ============================================================
       TESTIMONIALE „Ce spun ele" — slider (un singur testimonial vizibil),
       ca pe live: fotografie pe fundal + card alb cu citat/stele/nume,
       navigare prev/next cu JS vanilla minim (scroll-snap).
  ============================================================= -->
  <section class="testi-section">
    <div class="testi-bg-wrap" role="presentation">
      <Image class="testi-bg-img" src={imgTestimonialsBg} alt="" width={1920} height={1277} loading="lazy" />
    </div>
    <div class="wrap testi-inner">
      <div class="testi-content">
        <span class="eyebrow testi-eyebrow">Testimonial</span>
        <h2 class="testi-heading">Ce spun ele</h2>
        <span class="testi-quote" aria-hidden="true">&rdquo;</span>
        <div class="testi-track" data-testi-track>
          {testimonials.map((t) => <TestimonialCard {...t} />)}
        </div>
        <div class="testi-controls">
          <button type="button" class="testi-arrow" data-testi-prev aria-label="Testimonial anterior">‹</button>
          <button type="button" class="testi-arrow" data-testi-next aria-label="Testimonial următor">›</button>
        </div>
      </div>
    </div>
  </section>

  <script>
    const tracks = document.querySelectorAll('[data-testi-track]');
    tracks.forEach((el) => {
      const track = el;
      const card = track.closest('.testi-content');
      if (!card) return;
      const prevBtn = card.querySelector('[data-testi-prev]');
      const nextBtn = card.querySelector('[data-testi-next]');
      const getIndex = () => Math.round(track.scrollLeft / track.clientWidth);
      const goTo = (i) => {
        const count = track.children.length;
        const idx = ((i % count) + count) % count;
        const slide = track.children[idx];
        if (slide) track.scrollTo({ left: slide.offsetLeft, behavior: 'smooth' });
      };
      prevBtn?.addEventListener('click', () => goTo(getIndex() - 1));
      nextBtn?.addEventListener('click', () => goTo(getIndex() + 1));
    });
  </script>

