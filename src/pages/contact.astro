---
// Pagină unică „Contact" — slug exact din reference/site-inventory.md (/contact/).
// Layout replicat FIDEL după pagina live (https://deeabodycenter.ro/contact/):
//   1. InnerHero (bandă gri, „Contact" navy stânga + breadcrumb + poză promo contact.jpg dreapta)
//   2. „Unde ne găsești?" = titlu mare Playfair navy în corpul paginii + adresa (text simplu)
//   3. WhatsApp (fără formular) + hartă Google (în panou gri)
//   4. Bloc mare centrat „Programări telefonice la 0723 882 529" (Playfair navy)
// Telefonul + adresa sunt verbatim din pagina live. NU există formular (decizie de proiect).
import BaseLayout from '../layouts/BaseLayout.astro';
import InnerHero from '../components/InnerHero.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { site } from '../data/site';
---

<BaseLayout
  title="Contact - Deea Body Center"
  description="Contactează Deea Body Center Ploiești: Str. Vlad Țepeș nr. 21B, telefon 0723 882 529. Programează-te rapid prin WhatsApp sau telefonic."
  canonicalPath="/contact/"
>
  <!-- =========================================================
       HERO — bandă gri, titlu stânga + breadcrumb + poză promo
  ========================================================== -->
  <InnerHero
    title="Contact"
    breadcrumb={[{ label: 'Contact' }]}
    image="/images/contact-hero.jpg"
    imageAlt="Tratamente faciale pentru sezonul rece — Deea Body Center"
  />

  <!-- =========================================================
       UNDE NE GĂSEȘTI? — titlu secțiune + adresă (text simplu)
  ========================================================== -->
  <section class="find section">
    <div class="wrap">
      <h2 class="find__title">Unde ne găsești?</h2>
      <!-- Text verbatim de pe pagina live (fără diacritice pe „Tepes"/„Ploiesti") -->
      <p class="find__address">Str. Vlad Tepes nr. 21B. (in sensul giratoriu), Ploiesti, Romania.</p>
    </div>
  </section>

  <!-- =========================================================
       WHATSAPP (fără formular) + HARTĂ (în panou gri)
  ========================================================== -->
  <section class="locate">
    <div class="wrap">
      <img
        class="locate__dots"
        src="/pattern_1.png"
        width="193"
        height="75"
        alt=""
        aria-hidden="true"
        loading="lazy"
      />
      <div class="locate__grid">
        <div class="locate__cta">
          <p class="locate__lead">Scrie-ne pe WhatsApp și îți răspundem rapid pentru o programare la {site.name}.</p>
          <WhatsAppButton
            label="Scrie-ne pe WhatsApp"
            message="Bună, aș dori o programare la Deea Body Center."
            class="locate__btn"
          />
          <a href={site.phoneHref} class="locate__phone">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
              ><path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
              ></path></svg
            >
            {site.phone}
          </a>
        </div>

        <div class="locate__map">
          <iframe
            src="https://www.google.com/maps?q=Strada%20Vlad%20Tepes%2021B%2C%20Ploiesti%2C%20Romania&output=embed"
            width="600"
            height="450"
            style="border:0;"
            loading="lazy"
            title={`Locația ${site.name} pe hartă`}
          ></iframe>
          <a
            class="locate__map-link"
            href="https://www.google.com/maps/search/?api=1&query=Strada%20Vlad%20Tepes%2021B%2C%20Ploiesti%2C%20Romania"
            target="_blank"
            rel="noopener"
          >
            Deschide în Google Maps ↗
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- =========================================================
       PROGRAMĂRI TELEFONICE — bloc mare centrat
  ========================================================== -->
  <section class="phone-block" id="programare">
    <div class="wrap">
      <h3 class="phone-block__lead">Programări telefonice la</h3>
      <a href={site.phoneHref} class="phone-block__number">{site.phone}</a>
    </div>
  </section>
</BaseLayout>

<style>
  .wrap {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 15px;
  }

  /* ===== UNDE NE GĂSEȘTI ===== */
  .section {
    padding: 64px 0 8px;
    background: var(--surface);
  }
  .find__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 50px;
    line-height: 1.1;
    color: var(--navy);
    margin: 0 0 20px;
  }
  .find__address {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-sec);
    margin: 0;
  }

  /* ===== WHATSAPP + HARTĂ ===== */
  .locate {
    padding: 40px 0 72px;
    background: var(--surface);
    position: relative;
  }
  .locate .wrap {
    position: relative;
  }
  .locate__dots {
    position: absolute;
    top: -22px;
    left: -50px;
    width: 193px;
    height: 75px;
    display: block;
    z-index: 0;
    pointer-events: none;
  }
  .locate__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
  }
  .locate__cta {
    padding: 8px 8px 8px 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .locate__lead {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--heading);
    margin: 0 0 26px;
    max-width: 440px;
  }
  .locate__cta :global(.locate__btn) {
    padding: 16px 34px;
    font-size: 1rem;
  }
  .locate__phone {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 22px;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--heading);
  }
  .locate__phone svg {
    color: var(--magenta);
    flex-shrink: 0;
  }
  .locate__phone:hover {
    color: var(--magenta);
    text-decoration: none;
  }

  .locate__map {
    background: #ecf0f2;
    padding: 16px;
    border-radius: var(--r-md);
  }
  .locate__map iframe {
    display: block;
    width: 100%;
    height: 420px;
    border-radius: 6px;
  }
  .locate__map-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 12px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--magenta);
  }
  .locate__map-link:hover {
    color: var(--navy);
    text-decoration: none;
  }

  /* ===== PROGRAMĂRI TELEFONICE ===== */
  .phone-block {
    padding: 40px 0 88px;
    background: var(--surface);
    text-align: center;
  }
  .phone-block__lead {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 31px;
    line-height: 1.2;
    color: var(--navy);
    margin: 0 0 6px;
  }
  .phone-block__number {
    display: inline-block;
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 50px;
    line-height: 1.1;
    color: var(--navy);
    letter-spacing: 0.01em;
  }
  .phone-block__number:hover {
    color: var(--magenta);
    text-decoration: none;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .section {
      padding: 44px 0 8px;
    }
    .find__title {
      font-size: 34px;
    }
    .locate__grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .locate__dots {
      left: 0;
      top: -12px;
    }
    .locate__map iframe {
      height: 340px;
    }
    .phone-block__lead {
      font-size: 24px;
    }
    .phone-block__number {
      font-size: 38px;
    }
  }
  @media (max-width: 600px) {
    .locate__dots {
      display: none;
    }
  }
</style>
