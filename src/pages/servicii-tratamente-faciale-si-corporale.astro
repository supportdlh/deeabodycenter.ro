---
// Pagină unică „Hub servicii" — slug exact din reference/site-inventory.md
// (/servicii-tratamente-faciale-si-corporale/).
// Intro + titluri de secțiune PORTATE FIDEL din pagina live (curl 2026-07-05) — identice cu cele
// deja folosite pe homepage (index.astro), unde au fost la rândul lor scrapuite din același site.
// Grilele de carduri listează TOATE cele 17 tratamente din colecția `treatments` (nu doar
// subseturile parțiale de pe homepage), grupate pe categorie și ordonate după câmpul `order`
// (sursă unică de adevăr — vezi src/content.config.ts), în aceeași ordine de secțiuni (Corporal
// apoi Facial) ca pe pagina live.
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ContactBlock from '../components/ContactBlock.astro';

const treatments = await getCollection('treatments');

const corporal = treatments.filter((t) => t.data.category === 'corporal').sort((a, b) => a.data.order - b.data.order);
const facial = treatments.filter((t) => t.data.category === 'facial').sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Servicii Tratamente Faciale si Corporale - Deea Body Center"
  description="Servicii tratamente faciale și corporale de top la Deea Body Center Ploiești! Revitalizează-ți tenul și conturează-ți corpul."
  canonicalPath="/servicii-tratamente-faciale-si-corporale/"
>
  <!-- =========================================================
       PAGE HEADER
  ========================================================== -->
  <section class="page-header">
    <div class="wrap">
      <div class="eyebrow eyebrow--gold" style="justify-content:center">Deea Body Center</div>
      <h1>Servicii tratamente faciale si corporale</h1>
      <p>
        Descoperă servicii de tratamente faciale și corporale de top la Deea Body Center Ploiești! Revitalizează-ți
        tenul și conturează-ți corpul cu soluții personalizate și eficiente.
      </p>
      <p>La Deea Body Center combinăm tratamente faciale și corporale pentru o piele revitalizată și o siluetă sculptată, perfectă pentru tine.</p>
    </div>
  </section>

  <!-- =========================================================
       TRATAMENTE CORPORALE (9)
  ========================================================== -->
  <section class="section">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">Deea Body Center</div>
        <h2>Corpul pe care ți-l dorești, la un pas distanță!</h2>
        <p>La Deea Body Center, obții un corp tonifiat prin tratamente corporale personalizate, cu rezultate vizibile.</p>
      </div>
      <div class="svc-grid">
        {
          corporal.map((entry) => (
            <ServiceCard title={entry.data.title} excerpt={entry.data.excerpt} image={entry.data.heroImage} href={`/${entry.id}/`} />
          ))
        }
      </div>
    </div>
  </section>

  <!-- =========================================================
       TRATAMENTE FACIALE (8)
  ========================================================== -->
  <section class="section--alt">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">Deea Body Center</div>
        <h2>Tenul pe care ți-l dorești, la un pas distanță!</h2>
        <p>La Deea Body Center, obții un ten radiant prin tratamente faciale personalizate, cu rezultate vizibile.</p>
      </div>
      <div class="svc-grid">
        {
          facial.map((entry) => (
            <ServiceCard title={entry.data.title} excerpt={entry.data.excerpt} image={entry.data.heroImage} href={`/${entry.id}/`} />
          ))
        }
      </div>
    </div>
  </section>

  <!-- =========================================================
       CTA — PROGRAMARE WHATSAPP (fără formular)
  ========================================================== -->
  <section class="section" id="programare">
    <div class="wrap wrap--narrow">
      <ContactBlock />
    </div>
  </section>
</BaseLayout>

<style>
  .wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
  }
  .wrap--narrow {
    max-width: 640px;
  }

  .eyebrow {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: normal;
    text-transform: none;
    color: var(--teal);
    margin-bottom: 16px;
  }
  .eyebrow--gold {
    color: var(--gold);
  }

  /* ===== PAGE HEADER ===== */
  .page-header {
    background: var(--navy);
    padding: 88px 0 64px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -80px;
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, rgba(28, 114, 97, 0.14) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  .page-header .wrap {
    position: relative;
    max-width: 760px;
  }
  .page-header h1 {
    color: #fff;
    margin-bottom: 18px;
  }
  .page-header p {
    color: rgba(255, 255, 255, 0.78);
    font-size: 1.0625rem;
    line-height: 1.7;
  }
  .page-header p + p {
    margin-top: 10px;
  }

  /* ===== SECTIONS ===== */
  .section {
    padding: 80px 0;
    background: var(--surface);
  }
  .section--alt {
    padding: 80px 0;
    background: var(--surface-alt);
  }

  .sec-head {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 48px;
  }
  .sec-head h2 {
    margin-bottom: 12px;
  }
  .sec-head p {
    font-size: 1.0625rem;
  }

  /* ===== SERVICE GRID ===== */
  .svc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .svc-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 768px) {
    .page-header {
      padding: 64px 0 48px;
    }
    .section,
    .section--alt {
      padding: 56px 0;
    }
  }
  @media (max-width: 600px) {
    .svc-grid {
      grid-template-columns: 1fr;
    }
    .wrap {
      padding: 0 20px;
    }
  }
</style>
