---
// Pagină unică „Hub servicii" — slug exact din reference/site-inventory.md
// (/servicii-tratamente-faciale-si-corporale/).
// HERO + intro portate FIDEL din pagina live (curl/Playwright 2026-07-05):
//   - InnerHero (bandă gri, titlu navy stânga + breadcrumb + poză corporală dreapta + puncte teal)
//   - intro: paragraf navy cu clauză teal inline + al doilea paragraf navy + iconițe social
//   - în spatele grupurilor de carduri: decorațiuni gri-deschis „rectangle" (pătrat sus-dreapta +
//     pătrat jos-stânga, staggered), exact ca pe live (rectangle-2.png, 25% / 20%).
// Grilele de carduri listează TOATE cele 17 tratamente din colecția `treatments`, grupate pe
// categorie și ordonate după câmpul `order` (sursă unică — src/content.config.ts), în aceeași
// ordine (Corporal apoi Facial) ca pe pagina live.
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import InnerHero from '../components/InnerHero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ContactBlock from '../components/ContactBlock.astro';
import { site } from '../data/site';

const treatments = await getCollection('treatments');

const corporal = treatments.filter((t) => t.data.category === 'corporal').sort((a, b) => a.data.order - b.data.order);
const facial = treatments.filter((t) => t.data.category === 'facial').sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Servicii Tratamente Faciale si Corporale - Deea Body Center"
  description="Servicii tratamente faciale și corporale de top la Deea Body Center Ploiești! Revitalizează-ți tenul și conturează-ți corpul."
  canonicalPath="/servicii-tratamente-faciale-si-corporale/"
>
  <!-- =========================================================
       INNER HERO (bandă gri-deschis) — replică live
  ========================================================== -->
  <InnerHero
    title="Servicii tratamente faciale si corporale"
    breadcrumb={[{ label: 'Servicii Tratamente Faciale si Corporale' }]}
    image="/top-oferte.jpg"
    imageAlt="Servicii tratamente faciale și corporale — Deea Body Center Ploiești"
  />

  <!-- =========================================================
       INTRO (paragraf navy cu clauză teal + paragraf navy) + social
  ========================================================== -->
  <section class="intro">
    <div class="wrap">
      <p class="intro-lead">
        Descoperă <a class="intro-teal" href="/servicii-tratamente-faciale-si-corporale/">servicii de tratamente
        faciale și corporale</a> de top la Deea Body Center Ploiești! Revitalizează-ți tenul și conturează-ți corpul
        cu soluții personalizate și eficiente.
      </p>
      <p class="intro-lead">
        La Deea Body Center combinăm tratamente faciale și corporale pentru o piele revitalizată și o siluetă
        sculptată, perfectă pentru tine.
      </p>
      <div class="intro-social">
        <a href={site.social.facebook || '#'} aria-label="Facebook">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
            ><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg
          >
        </a>
        <a href={site.social.instagram || '#'} aria-label="Instagram">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
            ><rect x="2" y="2" width="20" height="20" rx="5"></rect><path
              d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"
            ></line></svg
          >
        </a>
      </div>
    </div>
  </section>

  <!-- =========================================================
       TRATAMENTE CORPORALE — decorațiuni rectangle staggered
  ========================================================== -->
  <section class="section section--deco">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">Deea Body Center</div>
        <h2>Corpul pe care ți-l dorești, la un pas distanță!</h2>
        <p>La Deea Body Center, obții un corp tonifiat prin tratamente corporale personalizate, cu rezultate vizibile.</p>
      </div>
      <div class="svc-grid">
        {
          corporal.map((entry) => (
            <ServiceCard title={entry.data.title} excerpt={entry.data.excerpt} image={entry.data.heroImage} href={`/${entry.id}/`} />
          ))
        }
      </div>
    </div>
  </section>

  <!-- =========================================================
       TRATAMENTE FACIALE — decorațiuni rectangle staggered
  ========================================================== -->
  <section class="section section--deco">
    <div class="wrap">
      <div class="sec-head">
        <div class="eyebrow">Deea Body Center</div>
        <h2>Tenul pe care ți-l dorești, la un pas distanță!</h2>
        <p>La Deea Body Center, obții un ten radiant prin tratamente faciale personalizate, cu rezultate vizibile.</p>
      </div>
      <div class="svc-grid">
        {
          facial.map((entry) => (
            <ServiceCard title={entry.data.title} excerpt={entry.data.excerpt} image={entry.data.heroImage} href={`/${entry.id}/`} />
          ))
        }
      </div>
    </div>
  </section>

  <!-- =========================================================
       CTA — PROGRAMARE WHATSAPP (fără formular)
  ========================================================== -->
  <section class="section--alt" id="programare">
    <div class="wrap wrap--narrow">
      <ContactBlock />
    </div>
  </section>
</BaseLayout>

<style>
  .wrap {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 15px;
  }
  .wrap--narrow {
    max-width: 640px;
  }

  .eyebrow {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: normal;
    text-transform: none;
    color: var(--teal);
    margin-bottom: 16px;
  }

  /* ===== INTRO (sub bandă hero) ===== */
  .intro {
    background: var(--surface);
    padding: 28px 0 8px;
  }
  .intro-lead {
    color: var(--navy, #051145);
    font-size: 1.0625rem;
    line-height: 1.7;
    max-width: 640px;
    margin: 0 0 14px;
  }
  .intro-teal {
    color: var(--teal, #148a87);
    text-decoration: none;
  }
  .intro-teal:hover {
    text-decoration: underline;
  }
  .intro-social {
    display: flex;
    gap: 14px;
    margin-top: 22px;
  }
  .intro-social a {
    color: var(--navy, #051145);
    display: inline-flex;
    transition: color 0.2s ease;
  }
  .intro-social a:hover {
    color: var(--teal, #148a87);
  }

  /* ===== SECTIONS ===== */
  .section {
    padding: 80px 0;
    background: var(--surface);
  }
  .section--alt {
    padding: 72px 0;
    background: var(--surface-alt);
  }

  /* Decorațiuni gri-deschis „rectangle" — replică live:
     pătrat sus-dreapta (25%) + pătrat jos-stânga (20%), staggered, în spatele cardurilor. */
  .section--deco {
    position: relative;
    background-color: var(--surface);
    background-image: url('/images/rectangle-2.png'), url('/images/rectangle-2.png');
    background-position: 100% 0%, 0% 100%;
    background-size: 25%, 20%;
    background-repeat: no-repeat, no-repeat;
  }
  .section--deco .wrap {
    position: relative;
    z-index: 1;
  }

  .sec-head {
    text-align: center;
    max-width: 680px;
    margin: 0 auto 48px;
  }
  .sec-head h2 {
    margin-bottom: 12px;
  }
  .sec-head p {
    font-size: 1.0625rem;
  }

  /* ===== SERVICE GRID ===== */
  .svc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .svc-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 768px) {
    .section,
    .section--alt {
      padding: 56px 0;
    }
  }
  @media (max-width: 600px) {
    .svc-grid {
      grid-template-columns: 1fr;
    }
    .section--deco {
      background-size: 40%, 34%;
    }
  }
</style>
