---
// OfferLayout — paginile de OFERTE, reconstruite după LIVE (deeabodycenter.ro/oferte-*).
// Trei layout-uri distincte, alese după `data.category`:
//
//   • corporal  (/oferte-tratamente-corporale) — structura desktop live:
//       1. InnerHero (bandă gri, titlu serif navy + breadcrumb + foto hero + puncte teal)
//       2. BLOC PROMO INTRO (2 col): stânga = titlu + intro + „18 proceduri eficiente" +
//          bulete 🔥 + „Doar 1400 RON"; dreapta = imaginea promo (promo-dec-25.webp, badge -65%).
//       3. 3 CARDURI-IMAGINE „Abonament nr. 1/2/3" (grafice cu preț incrustat).
//       4. TABEL DE PREȚURI: cutii gri-deschis (#ECF0F2) în 2 coloane, fiecare cu preț serif
//          navy centrat + descriere centrată + iconița roz DEEA în dreapta (`packages`).
//       5. Proză intro (stânga) + ContactBlock WhatsApp (dreapta).
//
//   • facial   (/oferte-tratamente-faciale) — ca mai sus dar FĂRĂ bloc promo/carduri:
//       InnerHero → tabel de prețuri (5 cutii) → proză + contact. (Blocul „Green Peel 290 RON"
//       e mobile-only pe live, deci nu apare pe desktop — nu îl randăm.)
//
//   • mixt     (/oferte-speciale-…) — InnerHero → paragraf intro + iconițe sociale →
//       colaj 2×2 de imagini promoționale (`gallery`) → ContactBlock + FAQ „Întrebări și răspunsuri".
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import InnerHero from '../components/InnerHero.astro';
import ContactBlock from '../components/ContactBlock.astro';
import Accordion from '../components/Accordion.astro';
import { site } from '../data/site';

export interface Props {
  entry: CollectionEntry<'offers'>;
}

const { entry } = Astro.props;
const { data } = entry;

const cat = data.category;
const isMixt = cat === 'mixt';
const isCorporal = cat === 'corporal';
const isFacial = cat === 'facial';

// Proză descriptivă din `body` (paragrafe separate de linii goale).
const bodyParas = data.body
  .split(/\n{2,}/)
  .map((p) => p.trim())
  .filter(Boolean);
// Pe live, coloana-proză a paginilor corporale/faciale începe cu rezumatul (excerpt),
// urmat de paragrafele descriptive din `body`.
const paragraphs = [data.excerpt, ...bodyParas];

// Cutii de preț (tabelul) — se împart în două coloane, ca pe live:
//   corporale: 3 în stânga (cele detaliate) + restul în dreapta;
//   faciale:   2 în stânga + 3 în dreapta.
const packages = data.packages ?? [];
const splitIndex = isFacial ? 2 : 4;
const leftBoxes = packages.slice(0, splitIndex);
const rightBoxes = packages.slice(splitIndex);
const hasPriceTable = (isCorporal || isFacial) && packages.length > 0;

const cards = isCorporal ? (data.gallery ?? []) : [];
const promoImages = isMixt ? (data.gallery ?? []) : [];
const introPromo = data.introPromo;

// FAQ „Întrebări și răspunsuri" — apare pe pagina live „Oferte speciale", alături de contact
// (aceleași 4 Q&A ca pe homepage, copiate VERBATIM).
const faq = [
  {
    question: 'Cât durează rezultatele și de câte ședințe am nevoie pentru a vedea efecte?',
    answers: [
      'Rezultatele variază în funcție de tratament și de corpul fiecărei persoane.',
      'De obicei, se observă îmbunătățiri după 3-5 ședințe, dar pentru rezultate optime se recomandă un program complet de 6-10 ședințe, efectuate la intervale regulate.',
    ],
  },
  {
    question: 'Sunt aceste tratamente sigure și au efecte secundare?',
    answers: [
      'Tratamentele sunt sigure atunci când sunt realizate de personal instruit și cu echipamente de calitate.',
      'Pot apărea efecte secundare minore, precum roșeață sau senzație de căldură, dar acestea dispar de obicei în câteva ore.',
      'Consultăm fiecare client pentru a ne asigura că tratamentele sunt potrivite și sigure pentru el.',
    ],
  },
  {
    question:
      'Cum funcționează tratamentele de slăbire/localizare a grăsimii (ex. criolipoliză, cavitație, radiofrecvență)?',
    answers: [
      'Fiecare tratament are o metodă diferită de acțiune.',
      'De exemplu, criolipoliza răcește țesutul adipos pentru a distruge celulele de grăsime, cavitația utilizează ultrasunete pentru a descompune grăsimea, iar radiofrecvența încălzește țesuturile pentru a stimula producția de colagen și a reduce celulita.',
      'Toate sunt non-invazive și nedureroase.',
    ],
  },
  {
    question: 'Ce tipuri de tratamente faciale sunt potrivite pentru tipul meu de piele?',
    answers: [
      'Oferim o consultație inițială pentru a evalua tipul de piele și nevoile specifice ale fiecărui client.',
      'În funcție de aceasta, recomandăm tratamente precum curățare profundă, hidratare intensă, anti-îmbătrânire sau pentru pielea sensibilă/acneică.',
    ],
  },
];

const DEEA_ICON = '/deea-icon.webp';
---

<BaseLayout title={data.seo.title} description={data.seo.description} canonicalPath={`/${entry.id}/`}>
  <!-- ===== HERO ===== -->
  <InnerHero
    title={data.title}
    breadcrumb={[{ label: data.title }]}
    image="/top-oferte.jpg"
    imageAlt={`${data.title} — ${site.name} ${site.city}`}
  />

  <!-- ===== MIXT: paragraf intro + iconițe sociale ===== -->
  {
    isMixt && (
      <section class="mixt-intro">
        <div class="wrap">
          <p class="mixt-lead">
            La {site.name}, obții <strong>un corp tonifiat și un ten radiant</strong> prin{' '}
            <a href="/oferte-tratamente-corporale/">oferte de tratamente faciale și corporale</a> personalizate, cu
            rezultate vizibile.
          </p>
          <div class="mixt-social">
            <a href={site.social.facebook} aria-label="Facebook" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z" />
              </svg>
            </a>
            <a href={site.social.instagram} aria-label="Instagram" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <line x1="17.5" y1="6.5" x2="17.5" y2="6.5" />
              </svg>
            </a>
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== MIXT: colaj 2×2 imagini promoționale ===== -->
  {
    isMixt && promoImages.length > 0 && (
      <section class="promo-collage">
        <div class="wrap">
          <div class="collage-grid">
            {promoImages.map((src, i) => (
              <figure class="collage-item">
                <img src={src} alt={`${data.title} — ofertă ${i + 1}`} loading={i < 2 ? 'eager' : 'lazy'} />
              </figure>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== CORPORAL: bloc promo intro ===== -->
  {
    isCorporal && introPromo && (
      <section class="intro-promo">
        <div class="wrap intro-promo__grid">
          <div class="intro-promo__text">
            <h2 class="ip-heading">
              {introPromo.heading} <span class="ip-sparkle">✨</span>
            </h2>
            {introPromo.intro && <p class="ip-intro">{introPromo.intro}</p>}
            {introPromo.listLabel && <p class="ip-label">{introPromo.listLabel}</p>}
            {introPromo.items && introPromo.items.length > 0 && (
              <ul class="ip-bullets">
                {introPromo.items.map((it) => (
                  <li>
                    <span class="ip-bullet-emoji">{introPromo.bulletEmoji ?? '•'}</span>
                    {it}
                  </li>
                ))}
              </ul>
            )}
            <p class="ip-price">{introPromo.price}</p>
          </div>
          <div class="intro-promo__media">
            <img src={introPromo.image} alt={`${data.title} — abonament remodelare corporală`} loading="eager" />
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== CORPORAL: 3 carduri-imagine „Abonament nr. 1/2/3" ===== -->
  {
    isCorporal && cards.length > 0 && (
      <section class="ab-cards">
        <div class="wrap">
          <div class="ab-cards__grid">
            {cards.map((src, i) => (
              <figure class="ab-card">
                <img src={src} alt={`Abonament nr. ${i + 1} — ${data.title}`} loading="lazy" />
              </figure>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== CORPORAL / FACIAL: tabel de prețuri (cutii gri + iconiță DEEA) ===== -->
  {
    hasPriceTable && (
      <section class={`price-table${isFacial || isCorporal ? ' price-table--filled' : ''}`}>
        <div class="wrap">
          <div class="price-cols">
            {[leftBoxes, rightBoxes].map((col) => (
              <div class="price-col">
                {col.map((box) => (
                  <div class="price-box">
                    <div class="price-box__content">
                      <h3 class="price-box__price">{box.price}</h3>
                      <div class="price-box__desc">
                        {box.items.map((it) => (
                          <span>{it}</span>
                        ))}
                      </div>
                    </div>
                    <img class="price-box__icon" src={DEEA_ICON} alt="Deea Body Center" loading="lazy" width="118" height="118" />
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== ÎNCHEIERE: proză+contact (corporal/facial) sau contact+FAQ (mixt) ===== -->
  <section class="closing">
    <div class="wrap closing-grid">
      {
        isMixt ? (
          <>
            <ContactBlock />
            <div class="faq-col">
              <h2 class="faq-title">Întrebări și răspunsuri</h2>
              <p class="faq-sub">
                Răspunsuri la cele mai frecvente întrebări pe care le primim din partea clienților.
              </p>
              <div class="accordion">
                {faq.map((item) => (
                  <Accordion title={item.question}>
                    {item.answers.map((a) => (
                      <p>{a}</p>
                    ))}
                  </Accordion>
                ))}
              </div>
            </div>
          </>
        ) : (
          <>
            <div class="prose-col">
              {paragraphs.map((p) => (
                <p>{p}</p>
              ))}
            </div>
            <ContactBlock />
          </>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .wrap {
    max-width: 1170px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ===== MIXT: intro + social ===== */
  .mixt-intro {
    background: var(--surface);
    padding: 40px 0 8px;
  }
  .mixt-lead {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--text-sec);
    max-width: 640px;
  }
  .mixt-lead strong {
    color: var(--heading);
    font-weight: 700;
  }
  .mixt-lead a {
    color: var(--teal);
    font-weight: 600;
  }
  .mixt-social {
    display: flex;
    gap: 12px;
    margin-top: 22px;
  }
  .mixt-social a {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--navy);
    border: 1.5px solid var(--border);
    transition: color 0.15s, border-color 0.15s;
  }
  .mixt-social a:hover {
    color: var(--magenta);
    border-color: var(--magenta);
  }

  /* ===== MIXT: colaj 2×2 ===== */
  .promo-collage {
    background: var(--surface);
    padding: 40px 0 56px;
  }
  .collage-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 30px;
    max-width: 1120px;
    margin: 0 auto;
  }
  .collage-item {
    margin: 0;
    border-radius: 8px;
    overflow: hidden;
  }
  .collage-item img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ===== CORPORAL: bloc promo intro ===== */
  .intro-promo {
    background: var(--surface);
    padding: 56px 0 40px;
  }
  .intro-promo__grid {
    display: grid;
    grid-template-columns: 1fr 0.62fr;
    gap: 48px;
    align-items: start;
  }
  .ip-heading {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 2rem;
    line-height: 1.15;
    color: var(--navy);
    margin: 0 0 18px;
  }
  .ip-sparkle {
    font-family: 'Poppins', sans-serif;
  }
  .ip-intro {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-sec);
    margin: 0 0 18px;
  }
  .ip-label {
    font-size: 1rem;
    color: var(--text-sec);
    margin: 0 0 10px;
  }
  .ip-bullets {
    list-style: none;
    margin: 0 0 22px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .ip-bullets li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1rem;
    color: var(--text-sec);
  }
  .ip-bullet-emoji {
    font-family: 'Poppins', sans-serif;
  }
  .ip-price {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 1.75rem;
    color: var(--navy);
    margin: 0;
  }
  .intro-promo__media img {
    display: block;
    width: 100%;
    max-width: 340px;
    height: auto;
    border-radius: 8px;
    margin-left: auto;
  }

  /* ===== CORPORAL: 3 carduri-imagine ===== */
  .ab-cards {
    background: var(--surface);
    padding: 8px 0 40px;
  }
  .ab-cards__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }
  .ab-card {
    margin: 0;
    border-radius: 8px;
    overflow: hidden;
  }
  .ab-card img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ===== TABEL DE PREȚURI ===== */
  .price-table {
    background: var(--surface);
    padding: 24px 0 64px;
  }
  .price-cols {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
    align-items: start;
  }
  .price-col {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .price-box {
    background: transparent;
    border-radius: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 22px 18px 22px 24px;
  }
  /* Cutii cu fundal gri-deschis #ECF0F2 (verificat pe LIVE — atât corporale, cât și
     faciale au acest fill, cu colțuri rotunjite 10px, pe pagină albă). */
  .price-table--filled .price-box {
    background: #ecf0f2;
  }
  .price-box__content {
    flex: 1;
    text-align: center;
    min-width: 0;
  }
  .price-box__price {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 1.9375rem; /* 31px — LIVE */
    line-height: 1.2;
    color: var(--navy);
    margin: 8px 0 16px; /* LIVE: mt 8px / mb 16px */
  }
  .price-box__desc {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .price-box__desc span {
    font-size: 1rem;
    line-height: 1.5;
    color: var(--navy);
  }
  .price-box__icon {
    flex-shrink: 0;
    width: 118px; /* LIVE: ~118px square */
    height: auto;
    align-self: center;
  }

  /* ===== ÎNCHEIERE ===== */
  .closing {
    background: var(--surface);
    padding: 64px 0;
  }
  .closing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .prose-col p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-sec);
    margin-bottom: 16px;
  }
  .prose-col p:last-child {
    margin-bottom: 0;
  }
  .faq-title {
    font-size: 1.875rem;
    margin-bottom: 10px;
  }
  .faq-sub {
    font-size: 0.875rem;
    color: var(--text-sec);
    margin-bottom: 22px;
    line-height: 1.6;
  }
  .accordion {
    display: flex;
    flex-direction: column;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .intro-promo__grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .intro-promo__media img {
      max-width: 380px;
      margin: 0 auto;
    }
    .ab-cards__grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin: 0 auto;
      gap: 20px;
    }
    .price-cols {
      grid-template-columns: 1fr;
    }
    .closing-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .collage-grid {
      gap: 20px;
    }
  }
  @media (max-width: 560px) {
    .wrap {
      padding: 0 20px;
    }
    .collage-grid {
      grid-template-columns: 1fr;
      max-width: 420px;
      gap: 18px;
    }
    .price-box {
      padding: 18px 14px;
    }
    .price-box__icon {
      width: 84px;
    }
  }
</style>
