---
// OfferLayout — paginile de OFERTE, reconstruite IMAGE-BASED după LIVE
// (deeabodycenter.ro/oferte-*). Pe live, conținutul real al paginilor de ofertă
// NU sunt carduri-text de pachete, ci un COLAJ de IMAGINI PROMOȚIONALE (grafice
// „Ofertă"/„Abonament" cu prețuri incrustate). Structură replicată:
//   1. InnerHero — bandă gri, titlu serif navy la stânga + breadcrumb „Home › …”
//      + fotografia hero (top-oferte.jpg) sus-dreapta + decorațiune puncte teal.
//   2. Grilă de imagini promoționale (`data.gallery`) = conținutul real al ofertei.
//      - „Oferte speciale” (category `mixt`): 2×2, cu paragraful intro DEASUPRA grilei
//        și un bloc FAQ „Întrebări și răspunsuri” alături de contact (ca pe live).
//      - „corporale/faciale”: grilă de grafice promo, apoi intro (stânga) + contact.
//   3. Contact WhatsApp (ContactBlock — fără formular).
// Pachetele text (`data.packages`) rămân în frontmatter pentru SEO, dar NU se afișează
// (live e image-based). Fără hero foto full-bleed, fără eyebrow auriu, fără carduri de preț.
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import InnerHero from '../components/InnerHero.astro';
import ContactBlock from '../components/ContactBlock.astro';
import Accordion from '../components/Accordion.astro';
import { site } from '../data/site';

export interface Props {
  entry: CollectionEntry<'offers'>;
}

const { entry } = Astro.props;
const { data } = entry;

const isMixt = data.category === 'mixt';

// Intro narativ (proză din `body`, separată prin linii goale). Pe live, coloana
// intro începe cu rezumatul (excerpt) urmat de paragrafele descriptive — pentru
// paginile corporale/faciale îl prepend-uim; la „mixt” body === excerpt (un rând).
const paragraphs = data.body
  .split(/\n{2,}/)
  .map((p) => p.trim())
  .filter(Boolean);
const introParas = isMixt ? paragraphs : [data.excerpt, ...paragraphs];

const promoImages = data.gallery ?? [];
// Numărul de coloane al grilei promo: „mixt” = 2 (colaj 2×2, identic live);
// altfel o grafică unică se centrează, iar mai multe curg pe max 4 coloane.
const gridCols = isMixt ? 2 : promoImages.length === 1 ? 1 : Math.min(promoImages.length, 4);

// FAQ „Întrebări și răspunsuri” — apare pe pagina live „Oferte speciale”, alături
// de contact (aceleași 4 Q&A ca pe homepage/tarife, copiate VERBATIM).
const faq = [
  {
    question: 'Cât durează rezultatele și de câte ședințe am nevoie pentru a vedea efecte?',
    answers: [
      'Rezultatele variază în funcție de tratament și de corpul fiecărei persoane.',
      'De obicei, se observă îmbunătățiri după 3-5 ședințe, dar pentru rezultate optime se recomandă un program complet de 6-10 ședințe, efectuate la intervale regulate.',
    ],
  },
  {
    question: 'Sunt aceste tratamente sigure și au efecte secundare?',
    answers: [
      'Tratamentele sunt sigure atunci când sunt realizate de personal instruit și cu echipamente de calitate.',
      'Pot apărea efecte secundare minore, precum roșeață sau senzație de căldură, dar acestea dispar de obicei în câteva ore.',
      'Consultăm fiecare client pentru a ne asigura că tratamentele sunt potrivite și sigure pentru el.',
    ],
  },
  {
    question: 'Cum funcționează tratamentele de slăbire/localizare a grăsimii (ex. criolipoliză, cavitație, radiofrecvență)?',
    answers: [
      'Fiecare tratament are o metodă diferită de acțiune.',
      'De exemplu, criolipoliza răcește țesutul adipos pentru a distruge celulele de grăsime, cavitația utilizează ultrasunete pentru a descompune grăsimea, iar radiofrecvența încălzește țesuturile pentru a stimula producția de colagen și a reduce celulita.',
      'Toate sunt non-invazive și nedureroase.',
    ],
  },
  {
    question: 'Ce tipuri de tratamente faciale sunt potrivite pentru tipul meu de piele?',
    answers: [
      'Oferim o consultație inițială pentru a evalua tipul de piele și nevoile specifice ale fiecărui client.',
      'În funcție de aceasta, recomandăm tratamente precum curățare profundă, hidratare intensă, anti-îmbătrânire sau pentru pielea sensibilă/acneică.',
    ],
  },
];
---

<BaseLayout title={data.seo.title} description={data.seo.description} canonicalPath={`/${entry.id}/`}>
  <!-- ===== HERO (InnerHero — bandă gri, titlu + breadcrumb + foto + puncte teal) ===== -->
  <InnerHero
    title={data.title}
    breadcrumb={[{ label: data.title }]}
    image="/top-oferte.jpg"
    imageAlt={`${data.title} — ${site.name} ${site.city}`}
  />

  <!-- ===== INTRO (doar „mixt”: paragraf deasupra colajului, ca pe live) ===== -->
  {
    isMixt && (
      <section class="intro-top">
        <div class="wrap">
          {introParas.map((p) => (
            <p>{p}</p>
          ))}
        </div>
      </section>
    )
  }

  <!-- ===== COLAJ DE IMAGINI PROMOȚIONALE (conținutul real al ofertei) ===== -->
  {
    promoImages.length > 0 && (
      <section class="promo">
        <div class="wrap">
          <div class={`promo-grid promo-grid--cols-${gridCols}`}>
            {promoImages.map((src, i) => (
              <figure class="promo-item">
                <img src={src} alt={`${data.title} — ofertă ${i + 1}`} loading={i < 2 ? 'eager' : 'lazy'} />
              </figure>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ===== INTRO + CONTACT (corporale/faciale) sau CONTACT + FAQ („mixt”) ===== -->
  <section class="closing">
    <div class="wrap closing-grid">
      {
        isMixt ? (
          <>
            <ContactBlock />
            <div class="faq-col">
              <h2>Întrebări și răspunsuri</h2>
              <p class="faq-sub">Răspunsuri la cele mai frecvente întrebări pe care le primim din partea clienților.</p>
              <div class="accordion">
                {faq.map((item) => (
                  <Accordion title={item.question}>
                    {item.answers.map((a) => (
                      <p>{a}</p>
                    ))}
                  </Accordion>
                ))}
              </div>
            </div>
          </>
        ) : (
          <>
            <div class="intro-col">
              {introParas.map((p) => (
                <p>{p}</p>
              ))}
            </div>
            <ContactBlock />
          </>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .wrap {
    max-width: 1170px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ===== INTRO TOP (mixt) ===== */
  .intro-top {
    background: var(--surface);
    padding: 32px 0 8px;
  }
  .intro-top p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-sec);
    max-width: 900px;
  }

  /* ===== COLAJ PROMO ===== */
  /* padding-top mai mare ca să lase fotografia hero (care „atârnă" ~47px sub bandă)
     să nu se suprapună peste primul rând de grafice promo. */
  .promo {
    background: var(--surface);
    padding: 72px 0 56px;
  }
  .promo-grid {
    display: grid;
    gap: 24px;
    align-items: start;
    justify-content: center;
  }
  .promo-grid--cols-1 {
    grid-template-columns: minmax(0, 420px);
  }
  .promo-grid--cols-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    max-width: 1120px;
    margin: 0 auto;
  }
  .promo-grid--cols-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .promo-grid--cols-4 {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }
  .promo-item {
    margin: 0;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--sh-sm);
    background: #fff;
  }
  .promo-item img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ===== ÎNCHEIERE: intro/contact/FAQ ===== */
  .closing {
    background: var(--surface-alt);
    padding: 64px 0;
  }
  .closing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .intro-col p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-sec);
    margin-bottom: 16px;
  }
  .intro-col p:last-child {
    margin-bottom: 0;
  }

  .faq-col h2 {
    font-size: 1.875rem;
    margin-bottom: 10px;
  }
  .faq-sub {
    font-size: 0.875rem;
    color: var(--text-sec);
    margin-bottom: 22px;
    line-height: 1.6;
  }
  .accordion {
    display: flex;
    flex-direction: column;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .closing-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .promo-grid--cols-3,
    .promo-grid--cols-4 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 560px) {
    .wrap {
      padding: 0 20px;
    }
    .promo-grid {
      gap: 16px;
    }
    .promo-grid--cols-2,
    .promo-grid--cols-3,
    .promo-grid--cols-4 {
      grid-template-columns: 1fr;
      max-width: 420px;
      margin: 0 auto;
    }
  }
</style>
