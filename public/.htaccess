# Deea Body Center — Astro static pe shared hosting (Apache/LiteSpeed)

# --- Forțare HTTPS ---
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # /sitemap.xml → servește indexul generat de @astrojs/sitemap (rewrite intern, URL rămâne curat)
  # Astfel URL-ul de trimis în Search Console e mereu /sitemap.xml, dar conținutul e auto-generat la build.
  RewriteRule ^sitemap\.xml$ /sitemap-index.xml [L]
</IfModule>

# --- Compresie ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml \
    application/javascript application/json application/xml image/svg+xml \
    application/rss+xml font/ttf font/otf
</IfModule>

# --- Caching ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/xml "access plus 0 seconds"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# --- Headers ---
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  # Assets Astro cu hash în nume → cache imutabil pe termen lung
  <FilesMatch "\.(css|js|woff2|webp|avif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # HTML → mereu revalidat (conținutul se poate schimba)
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# URL-urile sunt directory-style (trailing slash) — Apache servește index.html
# implicit din fiecare director, deci nu e nevoie de reguli suplimentare de rewrite.
# 301-uri pentru URL-uri vechi diferite: NU sunt necesare (slug-urile sunt identice cu WordPress).
